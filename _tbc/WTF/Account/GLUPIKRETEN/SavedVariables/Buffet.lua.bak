["customMacros"] = {
["bandage"] = {
["name"] = "bandage",
["source"] = "local bests, cache, availables = ... -- Keep this\n\nlocal item = 0\nif bests.bandage then item = bests.bandage end\n\nreturn \"#showtooltip\\n/cast item:\" .. item, \"INV_Misc_QuestionMark\"",
},
["food"] = {
["name"] = "food",
["source"] = "local bests, cache, availables = ... -- Keep this\n\n-- Example for best food with default to hearthstone\nlocal bestfood = bests.conjuredFood or bests.wellFedFood or bests.food or 0\n\n-- For more info see the wiki here:\n-- https://github.com/HgAlexx/Buffet/wiki/Custom-Macro:-howto\n\n-- Must return: body [, icon]\nreturn \"#showtooltip\\n/cast item:\" .. bestfood, \"INV_Misc_QuestionMark\"",
},
["drink"] = {
["name"] = "drink",
["source"] = "local bests, cache, availables = ... -- Keep this\n\nlocal item = 0\nif bests.drink then item = bests.drink end\nif bests.conjuredDrink then item = bests.conjuredDrink end\n\nreturn \"#showtooltip\\n/cast item:\" .. item, \"INV_Misc_QuestionMark\"",
},
["hpotion"] = {
["name"] = "hpotion",
["source"] = "local bests, cache, availables = ... -- Keep this\n\nlocal item = 0\nif bests.healthPotion then item = bests.healthPotion end\n\nreturn \"#showtooltip\\n/cast item:\" .. item, \"INV_Misc_QuestionMark\"",
},
["mpotion"] = {
["name"] = "mpotion",
["source"] = "local bests, cache, availables = ... -- Keep this\n\nlocal item = 0\nif bests.manaPotion then item = bests.manaPotion end\n\nreturn \"#showtooltip\\n/cast item:\" .. item, \"INV_Misc_QuestionMark\"",
},
["hstone"] = {
["name"] = "hstone",
["source"] = "local bests, cache, availables = ... -- Keep this\n\nlocal item = 0\nif bests.healthstone then item = bests.healthstone end\n\nreturn \"#showtooltip\\n/cast item:\" .. item, \"INV_Misc_QuestionMark\"",
},
},
