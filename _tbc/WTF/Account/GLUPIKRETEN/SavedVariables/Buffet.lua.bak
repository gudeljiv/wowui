["name"] = "drink",
["source"] = "local bests, cache, availables = ... -- Keep this\n\nlocal item = 0\nif bests.drink then item = bests.drink end\nif bests.conjuredDrink then item = bests.conjuredDrink end\n\nreturn \"#showtooltip\\n/cast item:\" .. item, \"INV_Misc_QuestionMark\"",
},
