-- Track which slots are already assigned to prevent duplicates
-- Note: ActionSlotManager is the source of truth for all action bar data
KeybindManager.assignedSlots = {}

function KeybindManager:ClearAssignedSlots()
    wipe(self.assignedSlots)
end

function KeybindManager:MarkSlotAsAssigned(slot)
    if not slot then
        self:Debug("MarkSlotAsAssigned: nil slot provided")
        return
    end
    self.assignedSlots[slot] = true
end

function KeybindManager:IsSlotAssigned(slot)
    return self.assignedSlots[slot] == true
end

do -- Module Functions
    function KeybindManager:ModuleInitialize()
        -- ============================ MODULE ASSIGNMENT ============================
        -- Assign Ace3 modules directly (no metatable access)
        OptionsFactory = NAG:GetModule("OptionsFactory")
        ResetManager = NAG:GetModule("ResetManager")
        DisplayManager = NAG:GetModule("DisplayManager")

        self.managedFrames = {}
        isInitialScanComplete = false

        -- ActionSlotManager owns all action bar data - nothing to clear here

        -- Register confirmation popup for delete all overrides
        StaticPopupDialogs["NAG_KEYBIND_DELETE_ALL_CONFIRM"] = {
            text = "Are you sure you want to delete ALL keybind overrides? This cannot be undone.",
            button1 = "Yes, Delete All",
            button2 = "Cancel",
            OnAccept = function()
                self.db.char.keybindOverrides.spell = {}
                self.db.char.keybindOverrides.item = {}
                self.db.char.keybindOverrides.macro = {}
                self:Info("All keybind overrides have been deleted")
                self:UpdateAllKeybinds()
            end,
            timeout = 0,
            whileDead = true,
            hideOnEscape = true,
            preferredIndex = 3,
        }

        -- Slash commands are now handled via zero-boilerplate slashCommands table

        -- Register individual module settings
        ResetManager:RegisterPreservationGroup("keybindManager", {
            name = L["preservationKeybindmanager"] or "Keybind Manager Settings",
            description = L["preservationKeybindmanagerDescription"] or "Preserve keybind manager specific settings and configurations",
            settings = {
                char = { "keybindOverrides", "keybindSettings" },
                global = { "keybindConfig", "keybindPreferences" }
            },
            alwaysPreserve = false
        }, "KeybindManager")

        -- Register into shared UI Layout group
        ResetManager:RegisterPreservationGroup("uiLayout", {
            name = L["preservationUilayout"] or "UI Layout Settings",
            description = L["preservationUilayoutDescription"] or "Preserve UI layout and display settings across multiple modules",
            settings = {
                global = { "enableKeybinds", "keybindTextColor", "keybindTextFontSize", "keybindTextFont" }
            },
            alwaysPreserve = false
        }, "KeybindManager")
    end

    function KeybindManager:HandleKeybindCommand(input)
        if not input or input == "" then
            self:Print("NAG KeybindManager is active. Use /nagkeybinds scan to force rescan actions.")
            return
        end

        local command = strlower(input)

        if command == "scan" then
            self:ScanAllActions()
            self:UpdateAllKeybinds()
            self:Print("Action bar scan completed")
        elseif command == "help" then
            self:Print("NAG KeybindManager commands:")
            self:Print("  /nagkeybinds - Show status")
            self:Print("  /nagkeybinds scan - Force rescan all actions")
            self:Print("  /nagkeybinds help - Show this help")
        else
            self:Print("Unknown command: " .. input)
            self:Print("Use /nagkeybinds help for available commands")
        end
    end

    -- ============================ MIGRATION ============================

    --- Migrate keybindOverrides from PascalCase to camelCase keys
    --- Converts: Item -> item, Macro -> macro, Spell -> spell, etc.
    function KeybindManager:MigrateKeybindOverridesCase()
        local keybindOverrides = self.db.char.keybindOverrides
        if not keybindOverrides then
            return
        end

        -- Mapping from old PascalCase to new camelCase
        local keyMapping = {
            Item = "item",
            Macro = "macro",
            Spell = "spell",
            Companion = "companion",
            Mount = "mount",
            Equipmentset = "equipmentset",
            Text = "text",
            Texture = "texture",
            Flyout = "flyout"
        }

        local migrated = false

        -- Check each old key and migrate if it exists
        for oldKey, newKey in pairs(keyMapping) do
            if keybindOverrides[oldKey] and next(keybindOverrides[oldKey]) then
                -- Old key exists with data, migrate it
                if not keybindOverrides[newKey] then
                    keybindOverrides[newKey] = {}
                end

                -- Copy all entries from old key to new key
                for identifier, keybind in pairs(keybindOverrides[oldKey]) do
                    -- Only copy if not already in new key (preserve existing data)
                    if not keybindOverrides[newKey][identifier] then
                        keybindOverrides[newKey][identifier] = keybind
                    end
                end

                -- Remove old key after migration
                keybindOverrides[oldKey] = nil
                migrated = true

                self:Info(format("Migrated keybind overrides from '%s' to '%s'", oldKey, newKey))
            elseif keybindOverrides[oldKey] then
                -- Old key exists but is empty, just remove it
                keybindOverrides[oldKey] = nil
                migrated = true
            end
        end

        if migrated then
            -- Save the migrated data
            self:SetSetting("char", "keybindOverrides", keybindOverrides)
            self:Info("Keybind overrides migration completed")
        end
    end

    function KeybindManager:ModuleEnable()
        -- Don't do initial scan here - wait for PLAYER_LOGIN

        -- ============================ MIGRATION ============================
        self:MigrateKeybindOverridesCase()

        -- ============================ MODULE INITIALIZATION ============================
    end

    function KeybindManager:ModuleDisable()
        -- Cancel any pending timers

        self:CancelAllTimers()

        -- Clear assigned slots
        self:ClearAssignedSlots()

        -- Clean up managed frames
        if self.managedFrames then
            for frame in pairs(self.managedFrames) do
                if frame.keybindText then
                    frame.keybindText:Hide()
                    frame.keybindText:SetParent(nil)
                    frame.keybindText = nil
                end
                frame.keyBindManager = nil
                frame.UpdateKeybindText = nil
            end
            wipe(self.managedFrames)
        end

        -- ActionSlotManager owns all action bar data - nothing to clear here

        isInitialScanComplete = false
    end


end

do -- Options/Config Functions
    -- Helper function to get all player spells from spellbook (excluding passives and Auto Attack)
    local function GetPlayerSpells()
        local spells = {}
        local numTabs = WoWAPI.GetNumSpellTabs()
        if not numTabs or numTabs <= 0 then
            return spells
        end

        for i = 1, numTabs do
            local tabInfo = WoWAPI.GetSpellTabInfo(i)
            if tabInfo then
                local offset = tabInfo.itemIndexOffset
                local numSpells = tabInfo.numSpellBookItems
                if offset and numSpells then
                    for j = offset + 1, offset + numSpells do
                        -- Use WoWAPI.GetSpellBookItemName (returns table with name, spellType, spellID)
                        local itemNameInfo = WoWAPI.GetSpellBookItemName(j, BOOKTYPE_SPELL)
                        if itemNameInfo and itemNameInfo.name and itemNameInfo.spellID then
                            local spellName = itemNameInfo.name
                            local spellID = itemNameInfo.spellID

                            -- Filter out Auto Attack (spellID 6603) and similar auto-attack abilities
                            if spellID ~= 6603 and spellID ~= 5019 then
                                -- Check if this is a passive ability
                                local isPassive = IsPassiveSpell(spellID)

                                -- Only include active (non-passive) spells
                                if not isPassive then
                                    spells[spellID] = spellName
                                end
                            end
                        end
                    end
                end
            end
        end
        return spells
    end

    -- Options composer for UI integration (keybind options)
    --- @param options table The options table to modify
    --- @param context table The context object
    --- @return table The modified options table
    function KeybindManager:ui(options, context)
        -- Add Keybind Manager as its own top-level section under the UI tab (sibling to Display)
        if options.args then
            options.args.keybindManager = {
                type = "group",
                name = L["keybindManager"] or "Keybind Manager",
                desc = L["keybindManagerDesc"] or "Configure keybind display and overrides for abilities and items.",
                order = 10,     -- After frame settings
                args = {
                    displaySettings = {
                        type = "group",
                        name = L["displaySettings"] or "Display Settings",
                        order = 0,
                        inline = true,
                        args = {
                            enableKeybinds = OptionsFactory:CreateToggle(L["enableKeybinds"] or "Enable Keybinds", L["enableKeybindsDesc"] or "Show keybind text on spell icons",
                                function() return self.db.global.enableKeybinds end,
                                function(_, val)
                                    self.db.global.enableKeybinds = val
                                    self:UpdateAllKeybinds()
                                    NAG:SendMessage("NAG_KEYBIND_SETTING_CHANGED", "enableKeybinds", val)
                                end,
                                { order = 1 }
                            ),
                            primaryOnly = OptionsFactory:CreateToggle(L["primaryOnly"] or "Primary Icon Only", L["primaryOnlyDesc"] or "Show keybinds only on the primary (main) spell icon",
                                function() return self.db.global.enableKeybindsPrimaryOnly end,
                                function(_, val)
                                    self.db.global.enableKeybindsPrimaryOnly = val
                                    self:UpdateAllKeybinds()
                                    NAG:SendMessage("NAG_KEYBIND_SETTING_CHANGED", "enableKeybindsPrimaryOnly", val)
                                end,
                                { order = 2 }
                            ),
                            textColor = OptionsFactory:CreateColor(L["textColor"] or "Text Color", L["textColorDesc"] or "Color of the keybind text",
                                function() return unpack(self.db.global.keybindTextColor) end,
                                function(_, r, g, b, a)
                                    self.db.global.keybindTextColor = {r, g, b, a}
                                    self:UpdateAllKeybinds()
                                end,
                                { order = 3, hasAlpha = true }
                            ),
                        }
                    },
                    spellOverride = {
                        type = "group",
                        name = L["spellOverride"] or "Spell Override",
                        order = 1,
                        inline = true,
                        args = {
                            info = {
                                type = "description",
                                name = L["info"] or "Keybind overrides allow you to display custom keybinds for abilities that may not match your actual action bar keybinds. This is useful when using macros or addons that change ability locations.\n\nFormat: Use modifier keys like ALT-1, SHIFT-F, CTRL-2, or plain keys like F, G, 1, 2.",
                                order = 0,
                                fontSize = "medium",
                            },
                            spellSelect = {
                                type = "select",
                                name = L["spellSelect"] or "Select Spell or Macro",
                                desc = L["spellSelectDesc"] or "Choose a spell from your spellbook or a macro from your action bars (or use search)",
                                order = 1,
                                width = "normal",
                                get = function()
                                    -- Prefer currently selected macro, then spell
                                    if self.selectedMacroID then
                                        return "macro:" .. tostring(self.selectedMacroID)
                                    end
                                    if self.selectedSpellID then
                                        return self.selectedSpellID
                                    end
                                    -- If nothing selected, return first spell in list as default
                                    if not self.selectedSpellID then
                                        local spells = GetPlayerSpells()
                                        local sorted = {}
                                        for id, name in pairs(spells) do
                                            table.insert(sorted, {id = id, name = name})
                                        end
                                        table.sort(sorted, function(a, b)
                                            return strlower(a.name) < strlower(b.name)
                                        end)
                                        if #sorted > 0 then
                                            return sorted[1].id
                                        end
                                    end
                                    return ""
                                end,
                                set = function(_, value)
                                    -- Support selecting either a spell id (number) or macro ("macro:<id>")
                                    self.selectedSpellID = nil
                                    self.selectedMacroID = nil
                                    if type(value) == "string" and strsub(value, 1, 6) == "macro:" then
                                        self.selectedMacroID = tonumber(strsub(value, 7))
                                    else
                                        self.selectedSpellID = value
                                    end
                                end,
                                values = function()
                                    local result = {}

                                    -- Get spells from spellbook
                                    local spells = GetPlayerSpells()
                                    if spells and next(spells) then
                                        local sorted = {}
                                        for id, name in pairs(spells) do
                                            table.insert(sorted, {id = id, name = name})
                                        end
                                        table.sort(sorted, function(a, b)
                                            return strlower(a.name) < strlower(b.name)
                                        end)

                                        -- Build a pure key->label table (no numeric indices) to avoid duplicates
                                        for _, spell in ipairs(sorted) do
                                            local spellInfo = WoWAPI.GetSpellInfo(spell.id)
                                            local icon = spellInfo and spellInfo.iconID
                                            local iconTexture = icon and format("|T%s:16:16:0:0|t ", icon) or ""
                                            local label = iconTexture .. spell.name
                                            result[spell.id] = label
                                        end
                                    end

                                    -- Append macros detected on action bars (via ActionSlotManager)
                                    local ASM = NAG:GetModule("ActionSlotManager")
                                    if ASM and ASM.ActionSlotsBy and ASM.ActionSlotsBy.macro then
                                        local macroList = {}
                                        for macroID in pairs(ASM.ActionSlotsBy.macro) do
                                            local macroName, macroIcon = GetMacroInfo(macroID)
                                            if macroName then
                                                table.insert(macroList, {id = macroID, name = macroName, icon = macroIcon})
                                            end
                                        end
                                        table.sort(macroList, function(a, b)
                                            return strlower(a.name) < strlower(b.name)
                                        end)
                                        for _, m in ipairs(macroList) do
                                            local iconTexture = m.icon and format("|T%s:16:16:0:0|t ", m.icon) or ""
                                            local label = iconTexture .. "[Macro] " .. m.name
                                            result["macro:" .. tostring(m.id)] = label
                                        end
                                    end

                                    -- If still empty, add a placeholder message
                                    if not next(result) then
                                        result[""] = "|cffff0000No spells or macros found. Try reloading.|r"
                                    end

                                    return result
                                end,
                                sorting = function()
                                    -- Build combined list of keys with plain names (no icons) for stable A-Z sort
                                    local entries = {}
                                    local spells = GetPlayerSpells()
                                    for id, name in pairs(spells) do
                                        table.insert(entries, { key = id, name = name or "" })
                                    end
                                    -- Use ActionSlotManager directly (source of truth) like values function does
                                    local ASM = NAG:GetModule("ActionSlotManager")
                                    if ASM and ASM.ActionSlotsBy and ASM.ActionSlotsBy.macro then
                                        for macroID in pairs(ASM.ActionSlotsBy.macro) do
                                            local macroName, _ = GetMacroInfo(macroID)
                                            if macroName then
                                                table.insert(entries, { key = "macro:" .. tostring(macroID), name = macroName })
                                            end
                                        end
                                    end
                                    table.sort(entries, function(a, b)
                                        return strlower(a.name) < strlower(b.name)
                                    end)
                                    local order = {}
                                    for i = 1, #entries do
                                        order[i] = entries[i].key
                                    end
                                    return order
                                end,
                            },
                            spellSearch = {
                                type = "execute",
                                name = L["spellSearch"] or "Search",
                                desc = L["spellSearchDesc"] or "Open spell search with autocomplete",
                                order = 1.5,
                                width = "half",
                                func = function()
                                    -- Create a simple frame with our custom widget
                                    local AceGUI = ns.AceGUI or LibStub("AceGUI-3.0")
                                    local frame = AceGUI:Create("Frame")
                                    frame:SetTitle("Search Spells")
                                    frame:SetWidth(400)
                                    frame:SetHeight(250)
                                    frame:SetLayout("List")

                                    -- Hide the default status bar and expand content to the bottom
                                    if frame.SetStatusText then frame:SetStatusText("") end
                                    if frame.statustext then
                                        local statusbg = frame.statustext:GetParent()
                                        if statusbg and statusbg.Hide then statusbg:Hide() end
                                        frame.statustext:Hide()
                                    end
                                    if frame.content and frame.frame then
                                        frame.content:ClearAllPoints()
                                        frame.content:SetPoint("TOPLEFT", frame.frame, "TOPLEFT", 17, -27)
                                        frame.content:SetPoint("BOTTOMRIGHT", frame.frame, "BOTTOMRIGHT", -17, 15)
                                    end

                                    -- Create label
                                    local label = AceGUI:Create("Label")
                                    label:SetText("Type to search:")
                                    label:SetFullWidth(true)
                                    frame:AddChild(label)

                                    -- Create autocomplete widget placed directly under the label (layout-managed)
                                    local autocomplete = AceGUI:Create("NAG_SpellAutocomplete")
                                    autocomplete:SetLabel("")
                                    autocomplete:SetFullWidth(true)
                                    autocomplete:SetHeight(24)

                                    -- Get spells
                                    local spells = GetPlayerSpells()
                                    local sorted = {}
                                    for id, name in pairs(spells) do
                                        table.insert(sorted, {id = id, name = name})
                                    end
                                    table.sort(sorted, function(a, b)
                                        return strlower(a.name) < strlower(b.name)
                                    end)

                                    local suggestions = {}
                                    for _, spell in ipairs(sorted) do
                                        local spellInfo = WoWAPI.GetSpellInfo(spell.id)
                                        local icon = spellInfo and spellInfo.iconID or nil
                                        local iconTexture = icon and format("|T%s:16:16:0:0|t ", icon) or ""
                                        local displayText = iconTexture .. spell.name
                                        tinsert(suggestions, {
                                            value = spell.id,
                                            name = spell.name,
                                            displayText = displayText
                                        })
                                        self:Debug(format("Added spell: %s, displayText: %s", spell.name, displayText))
                                    end

                                    -- Include macros that are currently on action bars (via direct API calls)
                                    do
                                        -- Get macros from action bars directly since ActionSlotManager was removed
                                        for i = 1, 120 do -- Check all action bar slots
                                            local actionType, id = GetActionInfo(i)
                                            if actionType == "macro" and id then
                                                local macroName, macroIcon = GetMacroInfo(id)
                                                if macroName then
                                                    local iconTexture = macroIcon and format("|T%s:16:16:0:0|t ", macroIcon) or ""
                                                    local displayText = iconTexture .. "[Macro] " .. macroName
                                                    tinsert(suggestions, {
                                                        value = "macro:" .. tostring(id),
                                                        name = macroName,
                                                        displayText = displayText
                                                    })
                                                end
                                            end
                                        end
                                    end

                                    autocomplete:SetSpells(suggestions)
                                    autocomplete:SetCallback(function(selected)
                                        -- Support both spells (numeric id) and macros ("macro:<id>")
                                        self.selectedSpellID = nil
                                        self.selectedMacroID = nil
                                        if type(selected) == "string" and strsub(selected, 1, 6) == "macro:" then
                                            self.selectedMacroID = tonumber(strsub(selected, 7))
                                        else
                                            self.selectedSpellID = selected
                                        end
                                        -- Ensure dropdown is detached before releasing frame to avoid layout issues
                                        if autocomplete and autocomplete.dropdown then
                                            autocomplete.dropdown:Hide()
                                            autocomplete.dropdown:SetParent(nil)
                                        end
                                        -- Delay release one frame to avoid double-release during button click
                                        C_Timer.After(0, function()
                                            if frame and not frame.isQueuedForRelease then
                                                frame:Release()
                                            end
                                        end)
                                        -- Refresh options to show selected spell in dropdown
                                        ns.AceConfigRegistry:NotifyChange("NAG")
                                        if self.selectedSpellID then
                                            self:Debug(format("Selected spell: %d", self.selectedSpellID))
                                        elseif self.selectedMacroID then
                                            self:Debug(format("Selected macro: %d", self.selectedMacroID))
                                        end
                                    end)

                                    frame:AddChild(autocomplete)

                                    -- Note: Dropdown reparenting is now handled automatically by the widget
                                end,
                            },
                            keybindInput = {
                                type = "input",
                                name = L["keybindInput"] or "Keybind",
                                desc = L["keybindInputDesc"] or "Enter the keybind (e.g., ALT-1, SHIFT-F, CTRL-2, F, 1)",
                                order = 2,
                                width = "normal",
                                get = function() return self.selectedKeybind or "" end,
                                set = function(_, value)
                                    self.selectedKeybind = value
                                end,
                            },
                            addOverride = {
                                type = "execute",
                                name = L["addOverride"] or "Add Override",
                                desc = L["addOverrideDesc"] or "Add the keybind override for the selected spell",
                                order = 3,
                                func = function()
                                    if self.selectedKeybind and self.selectedKeybind ~= "" then
                                        if self.selectedSpellID then
                                            self:OverrideSpellKeybind(self.selectedSpellID, self.selectedKeybind)
                                            self:Info(format("Added spell keybind override: %d -> %s", self.selectedSpellID, self.selectedKeybind))
                                            self.selectedSpellID = nil
                                            self.selectedKeybind = ""
                                            return
                                        elseif self.selectedMacroID then
                                            self:OverrideMacroKeybind(self.selectedMacroID, self.selectedKeybind)
                                            self:Info(format("Added macro keybind override: %d -> %s", self.selectedMacroID, self.selectedKeybind))
                                            self.selectedMacroID = nil
                                            self.selectedKeybind = ""
                                            return
                                        end
                                    end
                                    self:Error("Please select a spell or macro and enter a keybind")
                                end,
                            },
                            deleteSelectedOverride = {
                                type = "execute",
                                name = L["deleteSelectedOverride"] or "Delete Selected Override",
                                desc = L["deleteSelectedOverrideDesc"] or "Remove the keybind override for the selected spell",
                                order = 4,
                                func = function()
                                    if self.selectedSpellID then
                                        self:OverrideSpellKeybind(self.selectedSpellID, nil)
                                        self:Info(format("Removed spell keybind override for: %d", self.selectedSpellID))
                                        self.selectedSpellID = nil
                                        self.selectedKeybind = ""
                                    elseif self.selectedMacroID then
                                        self:OverrideMacroKeybind(self.selectedMacroID, nil)
                                        self:Info(format("Removed macro keybind override for: %d", self.selectedMacroID))
                                        self.selectedMacroID = nil
                                        self.selectedKeybind = ""
                                    else
                                        self:Error("Please select a spell or macro to remove its override")
                                    end
                                end,
                            },
                        }
                    },
                    currentOverrides = {
                        type = "group",
                        name = L["currentOverrides"] or "Current Overrides",
                        order = 2,
                        inline = true,
                        args = (function()
                            local args = {}
                            local orderCounter = 1
                            local keybindOverrides = self.db.char.keybindOverrides

                            -- Spells header
                            args.spellsHeader = {
                                type = "header",
                                name = L["spellsHeader"] or "Spells",
                                order = orderCounter,
                            }
                            orderCounter = orderCounter + 1

                            -- Build per-row controls for spells
                            do
                                local entries = {}
                                for spellID, keybind in pairs(keybindOverrides.spell or {}) do
                                    local spellInfo = WoWAPI.GetSpellInfo(spellID)
                                    local name = spellInfo and spellInfo.name or "Unknown"
                                    local icon = spellInfo and spellInfo.iconID or nil
                                    table.insert(entries, { name = name, id = spellID, key = keybind, icon = icon })
                                end
                                table.sort(entries, function(a,b) return strlower(a.name) < strlower(b.name) end)

                                for i, e in ipairs(entries) do
                                    local rowKey = "spellRow_" .. tostring(e.id)
                                    args[rowKey .. "_label"] = {
                                        type = "description",
                                        name = format("|T%s:16:16:0:0|t %s: %s", e.icon or "", e.name, e.key),
                                        order = orderCounter,
                                        width = 1.9,
                                    }
                                    args[rowKey .. "_remove"] = {
                                        type = "execute",
                                        name = "",
                                        image = "Interface\\Buttons\\CancelButton-Up",
                                        imageWidth = 25,
                                        imageHeight = 25,
                                        order = orderCounter + 0.1,
                                        width = 0.1,
                                        func = function()
                                            self:OverrideSpellKeybind(e.id, nil)
                                            ns.AceConfigRegistry:NotifyChange("NAG")
                                        end
                                    }
                                    orderCounter = orderCounter + 1
                                end
                            end

                            -- Macros header
                            args.macrosHeader = {
                                type = "header",
                                name = L["macrosHeader"] or "Macros",
                                order = orderCounter,
                            }
                            orderCounter = orderCounter + 1

                            -- Build per-row controls for macros
                            do
                                local entries = {}
                                for macroID, keybind in pairs(keybindOverrides.macro or {}) do
                                    local name, icon = GetMacroInfo(macroID)
                                    name = name or ("Macro " .. tostring(macroID))
                                    table.insert(entries, { name = name, id = macroID, key = keybind, icon = icon })
                                end
                                table.sort(entries, function(a,b) return strlower(a.name) < strlower(b.name) end)

                                for i, e in ipairs(entries) do
                                    local rowKey = "macroRow_" .. tostring(e.id)
                                    args[rowKey .. "_label"] = {
                                        type = "description",
                                        name = format("|T%s:16:16:0:0|t [Macro] %s: %s", e.icon or "", e.name, e.key),
                                        order = orderCounter,
                                        width = 1.9,
                                    }
                                    args[rowKey .. "_remove"] = {
                                        type = "execute",
                                        name = "",
                                        image = "Interface\\Buttons\\UI-GroupLoot-Pass-Up",
                                        imageWidth = 25,
                                        imageHeight = 25,
                                        order = orderCounter + 0.1,
                                        width = 0.1,
                                        func = function()
                                            self:OverrideMacroKeybind(e.id, nil)
                                            ns.AceConfigRegistry:NotifyChange("NAG")
                                        end
                                    }
                                    orderCounter = orderCounter + 1
                                end
                            end

                            if orderCounter == 3 then
                                -- No rows added
                                args.empty = {
                                    type = "description",
                                    name = L["empty"] or "No overrides set.",
                                    order = orderCounter,
                                    width = "full",
                                }
                            end

                            return args
                        end)()
                    },
                    deleteAllOverrides = {
                        type = "execute",
                        name = "|cFFFF0000Delete All Overrides|r",
                        desc = L["deleteAllOverridesDesc"] or "Remove all keybind overrides (requires confirmation)",
                        order = 4,
                        func = function()
                            StaticPopup_Show("NAG_KEYBIND_DELETE_ALL_CONFIRM")
                        end,
                    },
                    -- Per-group keybind display settings
                    groupDisplaySettings = {
                        type = "group",
                        name = L["groupDisplaySettings"] or "Per-Group Display Settings",
                        desc = L["groupDisplaySettingsDesc"] or "Configure keybind display (anchor, offset, font size) for each group",
                        order = 3,
                        childGroups = "tab",
                        args = (function()
                            local args = {}
                            -- Global Defaults tab for bulk Primary/Extra Groups configuration
                            args.quickSettings = {
                                type = "group",
                                name = L["quickSettings"] or "Global Defaults",
                                desc = L["quickSettingsDesc"] or "Configure default settings for all groups. These apply to all groups unless overridden by individual group settings.",
                                order = 0,
                                args = {
                                    globalDefaultsDesc = {
                                        type = "description",
                                        name = "|cff00ff00Global Defaults|r\n\nThese settings apply to all groups by default. Individual groups can override these settings in their own tabs.\n\n• |cffffd700Primary Group|r: Settings for the main/primary spell icon\n• |cffffd700Extra Groups|r: Settings for all other groups (Above, Below, Left, Right, AOE, Main, Cooldowns, Interrupts, Defensives, Sequence)",
                                        order = 1,
                                        fontSize = "medium",
                                        width = "full",
                                    },
                                    primaryHeader = {
                                        type = "header",
                                        name = L["primaryHeader"] or "Primary Group Defaults",
                                        order = 10,
                                    },
                                    primaryDesc = {
                                        type = "description",
                                        name = L["primaryDesc"] or "These settings apply to the primary (main) spell icon. This is the main spell recommendation shown in the center of your action guide.",
                                        order = 11,
                                        fontSize = "small",
                                        width = "full",
                                    },
                                    primaryFontSize = OptionsFactory:CreateRange(L["primaryFontSize"] or "Font Size", L["primaryFontSizeDesc"] or "Font size for keybind text on the primary spell icon. Recommended: 18-24 for better visibility.",
                                        function() return self.db.global.keybindTextFontSizePrimary or 18 end,
                                        function(_, val)
                                            self.db.global.keybindTextFontSizePrimary = val
                                            -- Update primary group setting
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            if not self.db.global.keybindGroups.primary then
                                                self.db.global.keybindGroups.primary = {}
                                            end
                                            self.db.global.keybindGroups.primary.fontSize = val
                                            self:UpdateAllKeybinds()
                                        end,
                                        { order = 12, min = 8, max = 32, step = 1 }
                                    ),
                                    primaryFont = OptionsFactory:CreateSelect(L["primaryFont"] or "Font", L["primaryFontDesc"] or "Font family for keybind text on the primary spell icon. Choose a font that's easy to read at a glance.",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local primary = groups and groups.primary
                                            return (primary and primary.font) or self.db.global.keybindTextFont or "Friz Quadrata TT"
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            if not self.db.global.keybindGroups.primary then
                                                self.db.global.keybindGroups.primary = {}
                                            end
                                            self.db.global.keybindGroups.primary.font = val
                                            self:UpdateAllKeybinds()
                                        end,
                                        {
                                            order = 13,
                                            values = function()
                                                return LSM:HashTable("font")
                                            end,
                                            dialogControl = "LSM30_Font"
                                        }
                                    ),
                                    primaryAnchor = OptionsFactory:CreateSelect(L["primaryAnchor"] or "Anchor Point", L["primaryAnchorDesc"] or "Determines which corner or edge of the spell icon the keybind text will be anchored to. BOTTOMLEFT is the most common choice.",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local primary = groups and groups.primary
                                            return (primary and primary.anchor) or "BOTTOMLEFT"
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            if not self.db.global.keybindGroups.primary then
                                                self.db.global.keybindGroups.primary = {}
                                            end
                                            self.db.global.keybindGroups.primary.anchor = val
                                            self:UpdateAllKeybinds()
                                        end,
                                        {
                                            order = 14,
                                            values = {
                                                TOPLEFT = "TOPLEFT",
                                                TOP = "TOP",
                                                TOPRIGHT = "TOPRIGHT",
                                                LEFT = "LEFT",
                                                CENTER = "CENTER",
                                                RIGHT = "RIGHT",
                                                BOTTOMLEFT = "BOTTOMLEFT",
                                                BOTTOM = "BOTTOM",
                                                BOTTOMRIGHT = "BOTTOMRIGHT",
                                            }
                                        }
                                    ),
                                    primaryOffsetX = OptionsFactory:CreateRange(L["primaryOffsetX"] or "Horizontal Offset", L["primaryOffsetXDesc"] or "Adjusts the horizontal position of the keybind text relative to its anchor point.\n\n• Negative values move text left\n• Positive values move text right\n• Recommended range: -5 to 5",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local primary = groups and groups.primary
                                            return (primary and primary.offsetX) or 2
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            if not self.db.global.keybindGroups.primary then
                                                self.db.global.keybindGroups.primary = {}
                                            end
                                            self.db.global.keybindGroups.primary.offsetX = val
                                            self:UpdateAllKeybinds()
                                        end,
                                        { order = 15, min = -50, max = 50, step = 1 }
                                    ),
                                    primaryOffsetY = OptionsFactory:CreateRange(L["primaryOffsetY"] or "Vertical Offset", L["primaryOffsetYDesc"] or "Adjusts the vertical position of the keybind text relative to its anchor point.\n\n• Negative values move text down\n• Positive values move text up\n• Recommended range: -5 to 5",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local primary = groups and groups.primary
                                            return (primary and primary.offsetY) or 2
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            if not self.db.global.keybindGroups.primary then
                                                self.db.global.keybindGroups.primary = {}
                                            end
                                            self.db.global.keybindGroups.primary.offsetY = val
                                            self:UpdateAllKeybinds()
                                        end,
                                        { order = 16, min = -50, max = 50, step = 1 }
                                    ),
                                    primaryReset = {
                                        type = "execute",
                                        name = L["primaryReset"] or "Reset Primary Defaults",
                                        desc = L["primaryResetDesc"] or "Reset all primary group settings to their default values",
                                        func = function()
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            if not self.db.global.keybindGroups.primary then
                                                self.db.global.keybindGroups.primary = {}
                                            end
                                            -- Reset to defaults
                                            self.db.global.keybindGroups.primary.font = nil
                                            self.db.global.keybindGroups.primary.fontSize = nil
                                            self.db.global.keybindGroups.primary.anchor = nil
                                            self.db.global.keybindGroups.primary.offsetX = nil
                                            self.db.global.keybindGroups.primary.offsetY = nil
                                            self.db.global.keybindTextFontSizePrimary = nil
                                            self:UpdateAllKeybinds()
                                            self:Info("Primary group defaults reset")
                                        end,
                                        order = 17
                                    },
                                    -- Extra groups settings
                                    extraHeader = {
                                        type = "header",
                                        name = L["extraHeader"] or "Extra Groups Defaults",
                                        order = 20,
                                    },
                                    extraDesc = {
                                        type = "description",
                                        name = L["extraDesc"] or "These settings apply to all extra groups (Above, Below, Left, Right, AOE, Main, Cooldowns, Interrupts, Defensives, Sequence) unless individually configured in their own tabs.",
                                        order = 21,
                                        fontSize = "small",
                                        width = "full",
                                    },
                                    extraFontSize = OptionsFactory:CreateRange(L["extraFontSize"] or "Font Size", L["extraFontSizeDesc"] or "Font size for keybind text on all extra group icons. Recommended: 12-16 for secondary icons.",
                                        function() return self.db.global.keybindTextFontSize or 12 end,
                                        function(_, val)
                                            self.db.global.keybindTextFontSize = val
                                            -- Update all extra groups
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            local extraGroups = {"above", "below", "left", "right", "aoe", "cooldowns", "interrupts", "defensives", "sequence"}
                                            for _, groupKey in ipairs(extraGroups) do
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].fontSize = val
                                            end
                                            self:UpdateAllKeybinds()
                                        end,
                                        { order = 22, min = 8, max = 32, step = 1 }
                                    ),
                                    extraFont = OptionsFactory:CreateSelect(L["extraFont"] or "Font", L["extraFontDesc"] or "Font family for keybind text on all extra group icons. This applies to Above, Below, Left, Right, AOE, Main, Cooldowns, Interrupts, Defensives, and Sequence groups.",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local above = groups and groups.above
                                            return (above and above.font) or self.db.global.keybindTextFont or "Friz Quadrata TT"
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            -- Update all extra groups (both legacy and modern)
                                            local extraGroups = {"above", "below", "left", "right", "aoe", "main", "cooldowns", "interrupts", "defensives", "sequence"}
                                            for _, groupKey in ipairs(extraGroups) do
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].font = val
                                            end
                                            -- Also update global font as fallback
                                            self.db.global.keybindTextFont = val
                                            self:UpdateAllKeybinds()
                                        end,
                                        {
                                            order = 23,
                                            values = function()
                                                return LSM:HashTable("font")
                                            end,
                                            dialogControl = "LSM30_Font"
                                        }
                                    ),
                                    extraAnchor = OptionsFactory:CreateSelect(L["extraAnchor"] or "Anchor Point", L["extraAnchorDesc"] or "Determines which corner or edge of the extra group icons the keybind text will be anchored to. BOTTOMLEFT is the most common choice.",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local above = groups and groups.above
                                            return (above and above.anchor) or "BOTTOMLEFT"
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            -- Update all extra groups
                                            local extraGroups = {"above", "below", "left", "right", "aoe", "cooldowns", "interrupts", "defensives", "sequence"}
                                            for _, groupKey in ipairs(extraGroups) do
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].anchor = val
                                            end
                                            self:UpdateAllKeybinds()
                                        end,
                                        {
                                            order = 24,
                                            values = {
                                                TOPLEFT = "TOPLEFT",
                                                TOP = "TOP",
                                                TOPRIGHT = "TOPRIGHT",
                                                LEFT = "LEFT",
                                                CENTER = "CENTER",
                                                RIGHT = "RIGHT",
                                                BOTTOMLEFT = "BOTTOMLEFT",
                                                BOTTOM = "BOTTOM",
                                                BOTTOMRIGHT = "BOTTOMRIGHT",
                                            }
                                        }
                                    ),
                                    extraOffsetX = OptionsFactory:CreateRange(L["extraOffsetX"] or "Horizontal Offset", L["extraOffsetXDesc"] or "Adjusts the horizontal position of the keybind text relative to its anchor point for all extra groups.\n\n• Negative values move text left\n• Positive values move text right\n• Recommended range: -5 to 5",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local above = groups and groups.above
                                            return (above and above.offsetX) or 2
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            -- Update all extra groups
                                            local extraGroups = {"above", "below", "left", "right", "aoe", "cooldowns", "interrupts", "defensives", "sequence"}
                                            for _, groupKey in ipairs(extraGroups) do
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].offsetX = val
                                            end
                                            self:UpdateAllKeybinds()
                                        end,
                                        { order = 25, min = -50, max = 50, step = 1 }
                                    ),
                                    extraOffsetY = OptionsFactory:CreateRange(L["extraOffsetY"] or "Vertical Offset", L["extraOffsetYDesc"] or "Adjusts the vertical position of the keybind text relative to its anchor point for all extra groups.\n\n• Negative values move text down\n• Positive values move text up\n• Recommended range: -5 to 5",
                                        function()
                                            local groups = self.db.global.keybindGroups
                                            local above = groups and groups.above
                                            return (above and above.offsetY) or 2
                                        end,
                                        function(_, val)
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            -- Update all extra groups
                                            local extraGroups = {"above", "below", "left", "right", "aoe", "cooldowns", "interrupts", "defensives", "sequence"}
                                            for _, groupKey in ipairs(extraGroups) do
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].offsetY = val
                                            end
                                            self:UpdateAllKeybinds()
                                        end,
                                        { order = 26, min = -50, max = 50, step = 1 }
                                    ),
                                    extraReset = {
                                        type = "execute",
                                        name = L["extraReset"] or "Reset Extra Groups Defaults",
                                        desc = L["extraResetDesc"] or "Reset all extra groups settings to their default values",
                                        func = function()
                                            if not self.db.global.keybindGroups then
                                                self.db.global.keybindGroups = {}
                                            end
                                            local extraGroups = {"above", "below", "left", "right", "aoe", "cooldowns", "interrupts", "defensives", "sequence"}
                                            for _, groupKey in ipairs(extraGroups) do
                                                if self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey].font = nil
                                                    self.db.global.keybindGroups[groupKey].fontSize = nil
                                                    self.db.global.keybindGroups[groupKey].anchor = nil
                                                    self.db.global.keybindGroups[groupKey].offsetX = nil
                                                    self.db.global.keybindGroups[groupKey].offsetY = nil
                                                end
                                            end
                                            self.db.global.keybindTextFontSize = nil
                                            self:UpdateAllKeybinds()
                                            self:Info("Extra groups defaults reset")
                                        end,
                                        order = 27
                                    },
                                }
                            }
                            local allGroups = {
                                -- Legacy groups (simplified names)
                                { key = "primary", name = "Primary", order = 1 },
                                { key = "above", name = "Above", order = 2 },
                                { key = "below", name = "Below", order = 3 },
                                { key = "left", name = "Left", order = 4 },
                                { key = "right", name = "Right", order = 5 },
                                { key = "aoe", name = "AOE", order = 6 },
                                -- Modern groups
                                { key = "main", name = "Main", order = 7 },
                                { key = "cooldowns", name = "Cooldowns", order = 8 },
                                { key = "interrupts", name = "Interrupts", order = 9 },
                                { key = "defensives", name = "Defensives", order = 10 },
                                { key = "sequence", name = "Sequence", order = 11 },
                            }

                            local anchorPoints = {
                                TOPLEFT = "TOPLEFT",
                                TOP = "TOP",
                                TOPRIGHT = "TOPRIGHT",
                                LEFT = "LEFT",
                                CENTER = "CENTER",
                                RIGHT = "RIGHT",
                                BOTTOMLEFT = "BOTTOMLEFT",
                                BOTTOM = "BOTTOM",
                                BOTTOMRIGHT = "BOTTOMRIGHT",
                            }

                            for _, group in ipairs(allGroups) do
                                local groupKey = group.key
                                args[groupKey] = {
                                    type = "group",
                                    name = group.name,
                                    desc = format("Configure keybind display settings specifically for the %s group. These settings override the global defaults.", group.name),
                                    order = group.order,
                                    args = {
                                        groupDesc = {
                                            type = "description",
                                            name = format("|cffffd700%s Group Settings|r\n\nConfigure individual settings for the %s group. These settings override the global defaults set in the 'Global Defaults' tab.", group.name, group.name),
                                            order = 0,
                                            fontSize = "medium",
                                            width = "full",
                                        },
                                        anchor = OptionsFactory:CreateSelect(L["optionsFactoryAnchor"] or "Anchor Point", L["anchorDesc"] or "Determines which corner or edge of the icon the keybind text will be anchored to. BOTTOMLEFT is the most common choice.",
                                            function()
                                                local keybindGroups = self.db.global.keybindGroups
                                                local groupSettings = keybindGroups and keybindGroups[groupKey]
                                                return (groupSettings and groupSettings.anchor) or "BOTTOMLEFT"
                                            end,
                                            function(_, val)
                                                if not self.db.global.keybindGroups then
                                                    self.db.global.keybindGroups = {}
                                                end
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].anchor = val
                                                self:UpdateAllKeybinds()
                                            end,
                                            {
                                                values = anchorPoints,
                                                order = 1,
                                            }
                                        ),
                                        offsetX = OptionsFactory:CreateRange(L["optionsFactoryOffsetX"] or "Horizontal Offset", L["offsetXDesc"] or "Adjusts the horizontal position of the keybind text relative to its anchor point.\n\n• Negative values move text left\n• Positive values move text right\n• Recommended range: -5 to 5",
                                            function()
                                                local keybindGroups = self.db.global.keybindGroups
                                                local groupSettings = keybindGroups and keybindGroups[groupKey]
                                                return (groupSettings and groupSettings.offsetX) or 2
                                            end,
                                            function(_, val)
                                                if not self.db.global.keybindGroups then
                                                    self.db.global.keybindGroups = {}
                                                end
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].offsetX = val
                                                self:UpdateAllKeybinds()
                                            end,
                                            {
                                                min = -50,
                                                max = 50,
                                                step = 1,
                                                order = 2,
                                            }
                                        ),
                                        offsetY = OptionsFactory:CreateRange(L["optionsFactoryOffsetY"] or "Vertical Offset", L["offsetYDesc"] or "Adjusts the vertical position of the keybind text relative to its anchor point.\n\n• Negative values move text down\n• Positive values move text up\n• Recommended range: -5 to 5",
                                            function()
                                                local keybindGroups = self.db.global.keybindGroups
                                                local groupSettings = keybindGroups and keybindGroups[groupKey]
                                                return (groupSettings and groupSettings.offsetY) or 2
                                            end,
                                            function(_, val)
                                                if not self.db.global.keybindGroups then
                                                    self.db.global.keybindGroups = {}
                                                end
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].offsetY = val
                                                self:UpdateAllKeybinds()
                                            end,
                                            {
                                                min = -50,
                                                max = 50,
                                                step = 1,
                                                order = 3,
                                            }
                                        ),
                                        fontSize = OptionsFactory:CreateRange(
                                            "Font Size",
                                            format("Font size for keybind text on %s group icons. Recommended: 12-18 for most groups, 18-24 for primary/main groups.", group.name),
                                            function()
                                                local keybindGroups = self.db.global.keybindGroups
                                                local groupSettings = keybindGroups and keybindGroups[groupKey]
                                                return (groupSettings and groupSettings.fontSize) or (groupKey == "primary" or groupKey == "main") and 18 or 12
                                            end,
                                            function(_, val)
                                                if not self.db.global.keybindGroups then
                                                    self.db.global.keybindGroups = {}
                                                end
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].fontSize = val
                                                self:UpdateAllKeybinds()
                                            end,
                                            {
                                                min = 8,
                                                max = 32,
                                                step = 1,
                                                order = 4,
                                            }
                                        ),
                                        font = OptionsFactory:CreateSelect(
                                            "Font",
                                            format("Font family for keybind text on %s group icons. Choose a font that's easy to read at a glance.", group.name),
                                            function()
                                                local keybindGroups = self.db.global.keybindGroups
                                                local groupSettings = keybindGroups and keybindGroups[groupKey]
                                                return (groupSettings and groupSettings.font) or self.db.global.keybindTextFont or "Friz Quadrata TT"
                                            end,
                                            function(_, val)
                                                if not self.db.global.keybindGroups then
                                                    self.db.global.keybindGroups = {}
                                                end
                                                if not self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey] = {}
                                                end
                                                self.db.global.keybindGroups[groupKey].font = val
                                                self:UpdateAllKeybinds()
                                            end,
                                            {
                                                order = 5,
                                                values = function()
                                                    return LSM:HashTable("font")
                                                end,
                                                dialogControl = "LSM30_Font"
                                            }
                                        ),
                                        resetGroup = {
                                            type = "execute",
                                            name = L["resetGroup"] or "Reset to Defaults",
                                            desc = format("Reset all %s group settings to their default values (will use Global Defaults)", group.name),
                                            func = function()
                                                if not self.db.global.keybindGroups then
                                                    self.db.global.keybindGroups = {}
                                                end
                                                if self.db.global.keybindGroups[groupKey] then
                                                    self.db.global.keybindGroups[groupKey].font = nil
                                                    self.db.global.keybindGroups[groupKey].fontSize = nil
                                                    self.db.global.keybindGroups[groupKey].anchor = nil
                                                    self.db.global.keybindGroups[groupKey].offsetX = nil
                                                    self.db.global.keybindGroups[groupKey].offsetY = nil
                                                end
                                                self:UpdateAllKeybinds()
                                                self:Info(format("%s group settings reset to defaults", group.name))
                                            end,
                                            order = 6
                                        },
                                    }
                                }
                            end

                            return args
                        end)(),
                    },
                }
            }
        end

        return options
    end

    function KeybindManager:NAG_KEYBIND_SETTING_CHANGED(message, setting, value)
        -- Only update overlays; ActionSlotManager owns all scanning now
        self:UpdateAllKeybinds()
    end

    function KeybindManager:UpdateAllKeybinds()
        if not self.managedFrames then return end

        -- Clear assigned slots before updating to ensure fresh assignments
        self:ClearAssignedSlots()

        for frame in pairs(self.managedFrames) do
            if frame.UpdateKeybindText then
                frame:UpdateKeybindText()
            end
        end
    end
end






function KeybindManager:ScanAllActions()
    if not self.db or not self.db.global.enableKeybinds then
        return
    end

    -- ActionSlotManager is the source of truth - we just update displays
    -- Clear assigned slots before updating displays
    self:ClearAssignedSlots()

    -- Update all keybind displays (ActionSlotManager already has the latest data)
    self:UpdateAllKeybinds()
end

do -- Event Handlers
    local function ThrottledScanAllActions(self)
        local currentTime = GetTime()
        if currentTime - lastScanTime < THROTTLE_INTERVAL then return end

        -- Clear assigned slots before scanning to ensure fresh assignments
        self:ClearAssignedSlots()

        self:ScanAllActions()
        lastScanTime = currentTime
    end

    function KeybindManager:PLAYER_LOGIN() end

    function KeybindManager:PLAYER_ENTERING_WORLD()
        -- Sync with ActionSlotManager when entering world
        if self.db and self.db.global.enableKeybinds then
            ThrottledScanAllActions(self)
        end
    end

    -- ACTIONBAR_SLOT_CHANGED, UPDATE_BINDINGS, UPDATE_MACROS are handled by ActionSlotManager
    -- ActionSlotManager notifies KeybindManager via ScanAllActions() or UpdateAllKeybinds()
    -- No need for KeybindManager to listen to these events directly
end

-- ============================ HELPER FUNCTIONS ============================

--- Get the current stance number (1-4) for stance classes
--- Warriors/Rogues/Druids use GetShapeshiftFormID() (more reliable with action bar addons)
--- Monks use GetBonusBarOffset() (works correctly for them)
--- @return number|nil The stance number (1-4) or nil if not in a stance
local function GetStanceNumber()
    local playerClass = NAG.CLASS_FILENAME
    local StateManager = NAG:GetModule("StateManager")
    local shapeshiftFormID = StateManager and StateManager:GetShapeshiftFormID() or nil

    if playerClass == "WARRIOR" then
        if shapeshiftFormID == 17 then return 1  -- Battle Stance
        elseif shapeshiftFormID == 18 then return 2  -- Defensive Stance
        elseif shapeshiftFormID == 19 then return 3  -- Berserker Stance
        end
    elseif playerClass == "ROGUE" then
        if shapeshiftFormID == 30 then return 1  -- Stealth
        end
    elseif playerClass == "DRUID" then
        if shapeshiftFormID == 1 then return 1  -- Cat
        elseif shapeshiftFormID == 5 then return 2  -- Bear
        elseif shapeshiftFormID == 31 or shapeshiftFormID == 35 then return 3  -- Moonkin
        elseif shapeshiftFormID == 2 then return 4  -- Tree of Life
        end
    elseif playerClass == "MONK" then
        -- Monks use GetBonusBarOffset for their stances (it works correctly for them)
        local BonusBarOffset = GetBonusBarOffset()
        if BonusBarOffset > 0 then return BonusBarOffset end
    end

    return nil
end

--- Get the group key from a frame (supports both legacy and modern groups)
--- @param frame table The frame to get the group from
--- @return string|nil The group key (lowercase)
local function GetGroupKeyFromFrame(frame)
    if not frame then return nil end

    -- Check modern groupKey first (FRAME_GROUPS constants are already lowercase strings)
    if frame.groupKey then
        -- frame.groupKey is already a lowercase string like "main", "cooldowns", etc.
        -- from ns.FRAME_GROUPS.MAIN, ns.FRAME_GROUPS.COOLDOWNS, etc.
        return type(frame.groupKey) == "string" and strlower(frame.groupKey) or tostring(frame.groupKey):lower()
    end

    -- Check legacy IsPrimary flag
    if frame.IsPrimary then
        return "primary"
    end

    -- Check frame name for legacy groups
    local frameName = frame.GetName and frame:GetName()
    if frameName then
        -- Legacy frame names like "NAG_FrameIconLeft1", "NAG_FrameIconAbove1", etc.
        if strfind(frameName, "Left") then
            return "left"
        elseif strfind(frameName, "Right") then
            return "right"
        elseif strfind(frameName, "Above") then
            return "above"
        elseif strfind(frameName, "Below") then
            return "below"
        elseif strfind(frameName, "AOE") or strfind(frameName, "Aoe") then
            return "aoe"
        end
    end

    return nil
end

--- Get per-group keybind settings with fallbacks
--- @param self table KeybindManager instance
--- @param groupKey string|nil The group key (lowercase)
--- @return table Settings table with anchor, offsetX, offsetY, fontSize
local function GetGroupKeybindSettings(self, groupKey)
    local defaults = {
        anchor = "BOTTOMLEFT",
        offsetX = 2,
        offsetY = 2,
        fontSize = 12,
    }

    if not self.db or not self.db.global then
        return defaults
    end

    -- If no group key, use legacy primary/non-primary logic
    if not groupKey then
        return {
            anchor = "BOTTOMLEFT",
            offsetX = 2,
            offsetY = 2,
            fontSize = self.db.global.keybindTextFontSize or 12,
        }
    end

    -- Get group-specific settings
    local keybindGroups = self.db.global.keybindGroups
    if not keybindGroups then
        return defaults
    end

    local groupSettings = keybindGroups[groupKey]
    if not groupSettings then
        -- Fallback to legacy font size for primary
        if groupKey == "primary" then
            return {
                anchor = "BOTTOMLEFT",
                offsetX = 2,
                offsetY = 2,
                fontSize = self.db.global.keybindTextFontSizePrimary or 18,
            }
        else
            return {
                anchor = "BOTTOMLEFT",
                offsetX = 2,
                offsetY = 2,
                fontSize = self.db.global.keybindTextFontSize or 12,
            }
        end
    end

    -- Merge with defaults to ensure all fields exist
    -- Font fallback: group-specific -> global -> default
    local font = groupSettings.font
    if not font and self.db.global.keybindTextFont then
        font = self.db.global.keybindTextFont
    end

    return {
        anchor = groupSettings.anchor or defaults.anchor,
        offsetX = groupSettings.offsetX or defaults.offsetX,
        offsetY = groupSettings.offsetY or defaults.offsetY,
        fontSize = groupSettings.fontSize or defaults.fontSize,
        font = font, -- Group-specific font with fallback to global
    }
end

function KeybindManager:AddKeybindToFrame(frame)
    if not frame then
        self:Debug("AddKeybindToFrame: nil frame provided")
        return
    end

    -- Clean up any existing keybind text
    if frame.keybindText then
        frame.keybindText:Hide()
        frame.keybindText:SetParent(nil)
        frame.keybindText = nil
    end

    -- Create the keybind text
    frame.keybindText = frame:CreateFontString(nil, "OVERLAY")
    if not frame.keybindText then
        self:Debug("AddKeybindToFrame: Failed to create font string")
        return
    end

    -- Get group key and settings
    local groupKey = GetGroupKeyFromFrame(frame)
    local groupSettings = GetGroupKeybindSettings(self, groupKey)

    -- Set up the font string with explicit font initialization and error checking
    local fontPath, fontSize
    if not self.db then
        self:Debug("AddKeybindToFrame: Database not initialized, using default font")
        fontPath = "Fonts\\FRIZQT__.TTF"
        fontSize = groupSettings.fontSize
    else
        -- Use group-specific font if available, otherwise use global font
        local fontName = groupSettings.font or self.db.global.keybindTextFont or "Friz Quadrata TT"
        fontPath = (ns.LibSharedMedia and ns.LibSharedMedia:Fetch("font", fontName)) or
            (ns.LibSharedMedia and ns.LibSharedMedia:GetDefault("font")) or
            "Fonts\\FRIZQT__.TTF"
        fontSize = groupSettings.fontSize
    end
    local fontFlags = "OUTLINE"

    -- Ensure the font exists and set it with error handling and diagnostics
    local success

    -- Validate fontPath and fontSize before calling SetFont
    if not fontPath or type(fontPath) ~= "string" then
        self:Error("Invalid fontPath: " .. tostring(fontPath))
        fontPath = "Fonts\\FRIZQT__.TTF"
    end

    if not fontSize or type(fontSize) ~= "number" then
        self:Error("Invalid fontSize: " .. tostring(fontSize))
        fontSize = 12
    end

    success = frame.keybindText:SetFont(fontPath, fontSize, fontFlags)

    if not success then
        -- Try system font as fallback
        fontPath = "Fonts\\FRIZQT__.TTF"
        success = frame.keybindText:SetFont(fontPath, fontSize, fontFlags)

        if not success then
            self:Error("Failed to set keybind text font")
            return
        end
    end

    -- Set anchor point and offset using per-group settings
    -- Anchor text to the frame using the specified anchor point
    frame.keybindText:SetPoint(groupSettings.anchor, frame, groupSettings.anchor, groupSettings.offsetX, groupSettings.offsetY)

    -- Set justify based on anchor point for proper text alignment
    local justifyH = "LEFT"
    local justifyV = "BOTTOM"
    if strfind(groupSettings.anchor, "RIGHT") then
        justifyH = "RIGHT"
    elseif strfind(groupSettings.anchor, "CENTER") or groupSettings.anchor == "LEFT" or groupSettings.anchor == "RIGHT" or groupSettings.anchor == "TOP" or groupSettings.anchor == "BOTTOM" then
        justifyH = "CENTER"
    end
    if strfind(groupSettings.anchor, "TOP") then
        justifyV = "TOP"
    elseif strfind(groupSettings.anchor, "CENTER") or groupSettings.anchor == "LEFT" or groupSettings.anchor == "RIGHT" or groupSettings.anchor == "TOP" or groupSettings.anchor == "BOTTOM" then
        justifyV = "MIDDLE"
    end

    frame.keybindText:SetJustifyH(justifyH)
    frame.keybindText:SetJustifyV(justifyV)

    -- Store group key on frame for later use
    frame._keybindGroupKey = groupKey

    -- Store reference to KeybindManager for use in frame methods
    frame.keyBindManager = self

    -- Register frame in managedFrames for UpdateAllKeybinds
    if not self.managedFrames then
        self.managedFrames = {}
    end
    self.managedFrames[frame] = true

    -- Add update method to frame
    function frame:UpdateKeybindText()
        local manager = self.keyBindManager
        if not manager then return end

        -- Check if keybinds are enabled (nil-safe pattern to handle false values)
        local enableKeybinds = true  -- default
        if manager.db and manager.db.global.enableKeybinds ~= nil then
            enableKeybinds = manager.db.global.enableKeybinds
        end

        local primaryOnly = false  -- default
        if manager.db and manager.db.global.enableKeybindsPrimaryOnly ~= nil then
            primaryOnly = manager.db.global.enableKeybindsPrimaryOnly
        end

        if not enableKeybinds or (primaryOnly and not self.IsPrimary) then
            self.keybindText:Hide()
            return
        end

        -- Get group key and settings (use stored group key if available)
        local groupKey = self._keybindGroupKey or GetGroupKeyFromFrame(self)

        -- Hard rule: always suppress keybinds on the AOE position/group
        -- (requested UX; keeps AOE icon clean).
        if groupKey == "aoe" then
            self.keybindText:Hide()
            return
        end

        local groupSettings = GetGroupKeybindSettings(manager, groupKey)

        -- Update font with error handling and diagnostics
        local fontPath, fontSize
        if not manager.db then
            fontPath = "Fonts\\FRIZQT__.TTF"
            fontSize = groupSettings.fontSize
        else
            -- Use group-specific font if available, otherwise use global font
            local fontName = groupSettings.font or manager.db.global.keybindTextFont or "Friz Quadrata TT"
            fontPath = (ns.LibSharedMedia and ns.LibSharedMedia:Fetch("font", fontName)) or
                (ns.LibSharedMedia and ns.LibSharedMedia:GetDefault("font")) or
                "Fonts\\FRIZQT__.TTF"
            fontSize = groupSettings.fontSize
        end

        -- Validate fontPath and fontSize before calling SetFont
        if not fontPath or type(fontPath) ~= "string" then
            manager:Error("Invalid fontPath in UpdateKeybindText: " .. tostring(fontPath))
            fontPath = "Fonts\\FRIZQT__.TTF"
        end

        if not fontSize or type(fontSize) ~= "number" then
            manager:Error("Invalid fontSize in UpdateKeybindText: " .. tostring(fontSize))
            fontSize = 12
        end

        local success = self.keybindText:SetFont(fontPath, fontSize or 12, "OUTLINE")

        if not success then
            -- Try system font as fallback
            fontPath = "Fonts\\FRIZQT__.TTF"
            success = self.keybindText:SetFont(fontPath, fontSize or 12, "OUTLINE")

            if not success then
                self.keybindText:Hide()
                return
            end
        end

        -- Update anchor point and offset using per-group settings
        self.keybindText:ClearAllPoints()
        self.keybindText:SetPoint(groupSettings.anchor, self, groupSettings.anchor, groupSettings.offsetX, groupSettings.offsetY)

        -- Update justify based on anchor point for proper text alignment
        local justifyH = "LEFT"
        local justifyV = "BOTTOM"
        if strfind(groupSettings.anchor, "RIGHT") then
            justifyH = "RIGHT"
        elseif strfind(groupSettings.anchor, "CENTER") or groupSettings.anchor == "LEFT" or groupSettings.anchor == "RIGHT" or groupSettings.anchor == "TOP" or groupSettings.anchor == "BOTTOM" then
            justifyH = "CENTER"
        end
        if strfind(groupSettings.anchor, "TOP") then
            justifyV = "TOP"
        elseif strfind(groupSettings.anchor, "CENTER") or groupSettings.anchor == "LEFT" or groupSettings.anchor == "RIGHT" or groupSettings.anchor == "TOP" or groupSettings.anchor == "BOTTOM" then
            justifyV = "MIDDLE"
        end

        self.keybindText:SetJustifyH(justifyH)
        self.keybindText:SetJustifyV(justifyV)

        -- Update color
        local r, g, b, a
        if manager.db then
            r, g, b, a = unpack(manager.db.global.keybindTextColor)
        else
            r, g, b, a = 1, 1, 1, 1 -- Default white color
        end
        self.keybindText:SetTextColor(r, g, b, a)

        -- Get and set keybind text
        local keybind = ""
        if self.macroId then
            -- Check for macro keybind first (macros have priority)
            keybind = manager:GetMacroKeybind(self.macroId) or ""
            if manager.debug and not keybind then
                manager:Debug("UpdateKeybindText: No keybind found for macroId %d (group: %s)", self.macroId, groupKey or "unknown")
            end
        elseif self.spellId then
            -- First try spell keybind
            keybind = manager:GetSpellKeybind(self.spellId) or ""

            -- Fallback: Check if this spellId comes from a macro on action bars
            -- This handles cases where a macro uses #showtooltip to display a spell
            -- We need to find which macro shows this spell and use its keybind
            if not keybind then
                -- Check all action bar slots (1-120 covers all standard action bars)
                for slot = 1, 120 do
                    local actionType, actionID = GetActionInfo(slot)
                    if actionType == "macro" and actionID then
                        -- Get macro info (name, icon, body)
                        local macroName, macroIcon, macroBody = GetMacroInfo(actionID)
                        if macroBody then
                            local macroShowsSpell = false

                            -- Check if macro uses #showtooltip with this spell
                            -- Parse macro body line by line
                            for line in string.gmatch(macroBody, "[^\r\n]+") do
                                -- Trim whitespace
                                line = string.gsub(line, "^%s*", "")
                                line = string.gsub(line, "%s*$", "")
                                -- Check for #showtooltip <spell> or #showtooltip <spellId>
                                local showtooltipMatch = string.match(line, "^#showtooltip%s+(.+)$")
                                if showtooltipMatch then
                                    -- Trim the match
                                    showtooltipMatch = string.gsub(showtooltipMatch, "^%s*", "")
                                    showtooltipMatch = string.gsub(showtooltipMatch, "%s*$", "")
                                    -- Try to match by spell ID first
                                    local tooltipSpellId = tonumber(showtooltipMatch)
                                    if tooltipSpellId == self.spellId then
                                        macroShowsSpell = true
                                        break
                                    end
                                    -- Try to match by spell name
                                    local spellInfo = WoWAPI.GetSpellInfo(self.spellId)
                                    if spellInfo and spellInfo.name then
                                        if strlower(showtooltipMatch) == strlower(spellInfo.name) then
                                            macroShowsSpell = true
                                            break
                                        end
                                    end
                                end
                            end

                            -- Also check GetMacroSpell as fallback (for macros that directly cast the spell)
                            if not macroShowsSpell then
                                local macroSpell = GetMacroSpell and GetMacroSpell(actionID)
                                if macroSpell == self.spellId then
                                    macroShowsSpell = true
                                end
                            end

                            if macroShowsSpell then
                                -- This macro shows/casts the displayed spell, check if it has a keybind
                                local macroKeybind = manager:GetMacroKeybind(actionID)
                                if macroKeybind then
                                    keybind = macroKeybind
                                    break
                                end
                            end
                        end
                    end
                end
            end

            if manager.debug and not keybind then
                manager:Debug("UpdateKeybindText: No keybind found for spellId %d (group: %s)", self.spellId, groupKey or "unknown")
            end
        elseif self.itemId then
            keybind = manager:GetItemKeybind(self.itemId) or ""
        end

        if keybind ~= "" then
            self.keybindText:SetText(keybind)
            self.keybindText:Show()
        else
            self.keybindText:Hide()
        end
    end

    -- Initial update
    frame:UpdateKeybindText()

    -- Frame already registered in managedFrames above (line 1927)
    -- No need to register again

    return frame
end

function KeybindManager:RemoveKeybindOverlay(frame)
    if not frame then return end
    if frame.keybindText then
        frame.keybindText:Hide()
        frame.keybindText:SetParent(nil)
        frame.keybindText = nil
    end
    frame.keyBindManager = nil
    frame.UpdateKeybindText = nil
end

do -- Public Keybind Getters
    -- Lightweight fallback scanner when ActionSlotManager is not available.
    -- Scans default action buttons 1-120 and returns a minimal action record with Keybind.
    local function FallbackScan(Type, ID)
        -- WoW returns Type as uppercase sometimes; normalize
        local function normalize(t)
            return t and strlower(t) or t
        end

        for slot = 1, 120 do
            local actionType, actionID = GetActionInfo(slot)
            actionType = normalize(actionType)
            if actionType == Type and actionID == ID then
                local commandName = format("ACTIONBUTTON%d", slot)
                local key = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                return {
                    ID = actionID,
                    Type = actionType,
                    Keybind = key,
                }
            end
        end

        return nil
    end

    local function FindAction(module, Type, ID)
        local ASM = NAG:GetModule("ActionSlotManager")
        if not ASM then
            -- Fallback: direct scan of action bars
            return FallbackScan(Type, ID)
        end

        -- Type should already be lowercase (all public APIs use lowercase)
        -- ActionSlotManager is the source of truth
        local ActionSlots = ASM and ASM.ActionSlotsBy and ASM.ActionSlotsBy[Type] and ASM.ActionSlotsBy[Type][ID]

        if not ActionSlots then
            -- If ASM has no data for this action, fall back to direct scan
            return FallbackScan(Type, ID)
        end

        local playerClass = NAG.CLASS_FILENAME
        local stanceNumber = GetStanceNumber and GetStanceNumber()

        -- For stance classes in a stance
        if stanceNumber and stanceNumber > 0 then
            -- Calculate current stance bar range
            local bonusBarStart = 73 + ((stanceNumber - 1) * 12)
            local bonusBarEnd = bonusBarStart + 11

            -- For Monks, visual bars don't swap, so prioritize regular bars over stance bars
            -- For other classes, stance bars replace the main bar, so check stance bars first
            if playerClass == "MONK" then
                -- Check regular bars first for Monks
                -- First check main bar (slots 1-12)
                for _, slot in pairs(ActionSlots) do
                    if slot <= 12 and not module:IsSlotAssigned(slot) then
                        local action = ASM.Actions and ASM.Actions[slot]
                        -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                        -- action.Type is always lowercase from WoW API
                        if action and action.ID == ID and (action.Type or "") == Type then
                            if not action.Keybind and not action.HotKey then
                                local commandName = ASM:GetCommandName(slot)
                                if commandName then
                                    action.Keybind = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                                end
                            elseif action.HotKey and not action.Keybind then
                                action.Keybind = action.HotKey
                            end
                            module:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end

                -- Then check other bars (excluding stance bars 73-120)
                for _, slot in pairs(ActionSlots) do
                    if slot > 12 and slot < 73 and not module:IsSlotAssigned(slot) then
                        local action = ASM.Actions and ASM.Actions[slot]
                        -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                        -- action.Type is always lowercase from WoW API
                        if action and action.ID == ID and (action.Type or "") == Type then
                            if not action.Keybind and not action.HotKey then
                                local commandName = ASM:GetCommandName(slot)
                                if commandName then
                                    action.Keybind = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                                end
                            elseif action.HotKey and not action.Keybind then
                                action.Keybind = action.HotKey
                            end
                            module:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end

                -- Finally check stance bars for Monks (but don't map to bar 1 - use actual keybind)
                for _, slot in pairs(ActionSlots) do
                    if slot >= bonusBarStart and slot <= bonusBarEnd and not module:IsSlotAssigned(slot) then
                        local action = ASM.Actions and ASM.Actions[slot]
                        -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                        -- action.Type is always lowercase from WoW API
                        if action and action.ID == ID and (action.Type or "") == Type then
                            -- For Monks, get the actual keybind for the stance bar slot, don't map to bar 1
                            if not action.Keybind and not action.HotKey then
                                local commandName = ASM:GetCommandName(slot)
                                if commandName then
                                    action.Keybind = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                                end
                            elseif action.HotKey and not action.Keybind then
                                action.Keybind = action.HotKey
                            end
                            module:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end
            else
                -- For Warriors/Rogues/Druids, stance bars replace main bar, so check stance bars first
                -- When in stance, check stance bar slots first (73-84 for stance 1)
                -- CRITICAL: When Dominos is active, it may show ALL stance bars (even inactive ones),
                -- so we need to check all stance bar slots (73-120), not just the active range
                local activeUI = DetectActiveUI()
                local checkAllStanceBars = (activeUI == SUPPORTED_UIS.DOMINOS)

                for _, slot in pairs(ActionSlots) do
                    local isInActiveStance = (slot >= bonusBarStart and slot <= bonusBarEnd)
                    local isStanceBarSlot = (slot >= 73 and slot <= 120)

                    -- Check slot if it's in active stance, OR if Dominos is active and it's any stance bar slot
                    if (isInActiveStance or (checkAllStanceBars and isStanceBarSlot)) and not module:IsSlotAssigned(slot) then
                        local action = ASM.Actions and ASM.Actions[slot]

                        -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                        -- action.Type is always lowercase from WoW API
                        if action and action.ID == ID and (action.Type or "") == Type then
                            local commandName = ASM:GetCommandName(slot)
                            if commandName then
                                local rawKeybind = GetBindingKey(commandName)
                                if rawKeybind then
                                    action.Keybind = KeybindManager:FormatKeybind(rawKeybind)
                                    module:MarkSlotAsAssigned(slot)
                                    return action
                                end
                            end
                        end
                    end
                end

                -- If no stance bar slot found, check regular bars (excluding stance bars 73-120)
                -- First check main bar (slots 1-12)
                for _, slot in pairs(ActionSlots) do
                    if slot <= 12 and slot < 73 and not module:IsSlotAssigned(slot) then
                        local action = ASM.Actions and ASM.Actions[slot]
                        -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                        -- action.Type is always lowercase from WoW API
                        if action and action.ID == ID and (action.Type or "") == Type then
                            -- Always recalculate keybind to avoid stale cache
                            local commandName = ASM:GetCommandName(slot)
                            if commandName then
                                action.Keybind = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                                module:MarkSlotAsAssigned(slot)
                                return action
                            end
                        end
                    end
                end

                -- Then check other bars (excluding stance bars 73-120)
                for _, slot in pairs(ActionSlots) do
                    if slot > 12 and slot < 73 and not module:IsSlotAssigned(slot) then
                        local action = ASM.Actions and ASM.Actions[slot]
                        -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                        -- action.Type is always lowercase from WoW API
                        if action and action.ID == ID and (action.Type or "") == Type then
                            -- Always recalculate keybind to avoid stale cache
                            local commandName = ASM:GetCommandName(slot)
                            if commandName then
                                action.Keybind = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                                module:MarkSlotAsAssigned(slot)
                                return action
                            end
                        end
                    end
                end
            end
        else
            -- When NOT in stance, ONLY check main bar and other bars (excluding stance bars)
            -- First check main bar (slots 1-12)
                for _, slot in pairs(ActionSlots) do
                    if slot <= 12 and not module:IsSlotAssigned(slot) then
                        local action = ASM.Actions and ASM.Actions[slot]
                        -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                        -- action.Type is always lowercase from WoW API
                        if action and action.ID == ID and (action.Type or "") == Type then
                            -- Ensure Keybind is set from HotKey or get it fresh
                            if not action.Keybind and not action.HotKey then
                                local commandName = ASM:GetCommandName(slot)
                                if commandName then
                                    action.Keybind = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                                end
                            elseif action.HotKey and not action.Keybind then
                                action.Keybind = action.HotKey
                            end
                            module:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end

            -- Then check other bars (excluding stance bars 73-120)
            for _, slot in pairs(ActionSlots) do
                if slot > 12 and slot < 73 and not module:IsSlotAssigned(slot) then
                    local action = ASM.Actions and ASM.Actions[slot]
                    -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                    -- action.Type is always lowercase from WoW API
                    if action and action.ID == ID and (action.Type or "") == Type then
                        -- Ensure Keybind is set from HotKey or get it fresh
                        if not action.Keybind and not action.HotKey then
                            local commandName = ASM:GetCommandName(slot)
                            if commandName then
                                action.Keybind = KeybindManager:FormatKeybind(GetBindingKey(commandName))
                            end
                        elseif action.HotKey and not action.Keybind then
                            action.Keybind = action.HotKey
                        end
                        module:MarkSlotAsAssigned(slot)
                        return action
                    end
                end
            end
        end

        return nil
    end

    function KeybindManager:GetKeybind(Type, Identifier)
        if not Type then
            self:Debug("GetKeybind: nil Type provided")
            return nil
        end

        -- Type should already be lowercase (all public APIs use lowercase)
        local keybindOverrides = self.db.char.keybindOverrides

        -- Clear assigned slots tracking for this lookup
        self:ClearAssignedSlots()

        -- CRITICAL: Check overrides FIRST - they always suppress the original keybind
        -- If an override exists, it takes priority over the actual action bar keybind
        if keybindOverrides[Type] and keybindOverrides[Type][Identifier] then
            self:Debug(format("Override found for %s %s: %s", Type, tostring(Identifier), keybindOverrides[Type][Identifier]))
            return keybindOverrides[Type][Identifier]
        end

        -- For spells, also check for name-based matches when exact ID doesn't match
        if Type == "spell" then
            local actionName = ResolveSpellName(Identifier)
            if actionName then
                local actionNameLower = strlower(actionName)
                for storedID, storedBind in pairs(keybindOverrides[Type] or {}) do
                    local storedName = ResolveSpellName(storedID)
                    if storedName and strlower(storedName) == actionNameLower then
                        return storedBind
                    end
                end
            end
        end

        -- Then check actual actions
        local Action = FindAction(self, Type, Identifier)
        if Action then
            -- CRITICAL: Always recalculate keybind from the actual slot to avoid stale cached values
            -- FindAction should have already set Action.Keybind, but verify it's correct by recalculating
            if Action.Slot then
                local ASM = NAG:GetModule("ActionSlotManager")
                local commandName = ASM:GetCommandName(Action.Slot)
                if commandName then
                    local rawKeybind = GetBindingKey(commandName)
                    if rawKeybind then
                        return self:FormatKeybind(rawKeybind)
                    end
                end
            end
            -- Fallback to cached values only if we can't get command name
            if Action.Keybind then
                return Action.Keybind
            elseif Action.HotKey then
                return Action.HotKey
            end
        end

        -- For spells, if no action found with exact ID, try to find by name in action slots
        if Type == "spell" and not Action then
            local actionName = ResolveSpellName(Identifier)
            if actionName then
                local actionNameLower = strlower(actionName)

                -- Search through all spell action slots for matching names
                -- Use ActionSlotManager (source of truth)
                local ASM = NAG:GetModule("ActionSlotManager")
                local matchingSpells = {}
                if ASM and ASM.ActionSlotsBy and ASM.ActionSlotsBy.spell then
                    for spellID, actionSlots in pairs(ASM.ActionSlotsBy.spell) do
                        local spellName = ResolveSpellName(spellID)
                        if spellName and strlower(spellName) == actionNameLower then
                            tinsert(matchingSpells, spellID)
                        end
                    end
                end

                -- Sort for consistent ordering
                sort(matchingSpells)

                -- Try each matching spell ID until we find one with an available slot
                for _, spellID in ipairs(matchingSpells) do
                    local matchingAction = FindAction(self, Type, spellID)
                    if matchingAction and matchingAction.Keybind then
                        return matchingAction.Keybind
                    end
                end
            end
        end

        return nil
    end

    function KeybindManager:GetSpellKeybind(SpellID)
        return self:GetKeybind("spell", SpellID)
    end

    function KeybindManager:GetItemKeybind(ItemID)
        return self:GetKeybind("item", ItemID)
    end

    function KeybindManager:GetMacroKeybind(MacroID)
        return self:GetKeybind("macro", MacroID)
    end

    function KeybindManager:GetTextureKeybind(icon)
        return self:GetKeybind("texture", icon)
    end

    function KeybindManager:GetBindingsByType(bindingType)
        -- bindingType should already be lowercase
        local bindings = {}

        -- Use ActionSlotManager (source of truth)
        local ASM = NAG:GetModule("ActionSlotManager")
        if not ASM or not ASM.ActionSlotsBy then
            return bindings
        end

        if bindingType == "spell" then
            -- First, add all spells that have actions on bars
            for spellID, slots in pairs(ASM.ActionSlotsBy.spell or {}) do
                local spellInfo = WoWAPI.GetSpellInfo(spellID)
                if spellInfo and spellInfo.name then
                    local binding = self:GetSpellKeybind(spellID)
                    if binding then
                        bindings[spellID] = {
                            name = spellInfo.name,
                            icon = spellInfo.iconID,
                            binding = binding,
                            slots = slots -- Only include if needed
                        }
                    end
                end
            end

            -- Also include any spell overrides that might not be on action bars currently
            local keybindOverrides = self.db.char.keybindOverrides
            if keybindOverrides.spell then
                for storedSpellID, keybind in pairs(keybindOverrides.spell) do
                    -- Only add if not already included from action bars
                    if not bindings[storedSpellID] then
                        local spellInfo = WoWAPI.GetSpellInfo(storedSpellID)
                        if spellInfo and spellInfo.name then
                            bindings[storedSpellID] = {
                                name = spellInfo.name,
                                icon = spellInfo.iconID,
                                binding = keybind,
                                slots = {} -- No slots since not on action bar
                            }
                        end
                    end
                end
            end
        elseif bindingType == "item" then
            for itemID, slots in pairs(ASM.ActionSlotsBy.item or {}) do
                local itemName, _, _, _, _, _, _, _, _, itemIcon = WoWAPI.GetItemInfo(itemID)
                if itemName then
                    local binding = self:GetItemKeybind(itemID)
                    if binding then
                        bindings[itemID] = {
                            name = itemName,
                            icon = itemIcon,
                            binding = binding,
                            slots = slots -- Only include if needed
                        }
                    end
                end
            end
        elseif bindingType == "macro" then
            for macroID, slots in pairs(ASM.ActionSlotsBy.macro or {}) do
                local macroName, macroIcon = GetMacroInfo(macroID)
                if macroName then
                    local binding = self:GetMacroKeybind(macroID)
                    if binding then
                        bindings[macroID] = {
                            name = macroName,
                            icon = macroIcon,
                            binding = binding,
                            slots = slots -- Only include if needed
                        }
                    end
                end
            end
        end
        return bindings
    end
end

do -- Public Keybind Override setters
    local function OverrideKeybind(module, Type, Identifier, Keybind)
        -- Type should already be lowercase (all public APIs use lowercase)
        local keybindOverrides = module.db.char.keybindOverrides
        if not keybindOverrides[Type] then
            keybindOverrides[Type] = {}
        end

        local oldKeybind = keybindOverrides[Type][Identifier]
        keybindOverrides[Type][Identifier] = Keybind

        -- If keybind was removed (set to nil), clean up the entry
        if not Keybind then
            keybindOverrides[Type][Identifier] = nil
        end

        -- Save the updated overrides
        module:SetSetting("char", "keybindOverrides", keybindOverrides)

        -- Immediately update all keybind frames
        module:UpdateAllKeybinds()
    end

    function KeybindManager:OverrideSpellKeybind(SpellID, Keybind)
        if not SpellID then return end
        OverrideKeybind(self, "spell", SpellID, Keybind)
    end

    function KeybindManager:OverrideItemKeybind(ItemID, Keybind)
        if not ItemID then return end
        OverrideKeybind(self, "item", ItemID, Keybind)
    end

    function KeybindManager:OverrideMacroKeybind(MacroID, Keybind)
        if not MacroID then return end
        OverrideKeybind(self, "macro", MacroID, Keybind)
    end

    -- Batch override function for multiple overrides at once
    function KeybindManager:SetMultipleOverrides(overrides)
        if not overrides or type(overrides) ~= "table" then
            return
        end

        local keybindOverrides = self.db.char.keybindOverrides
        local changesCount = 0

        for overrideType, typeOverrides in pairs(overrides) do
            if type(typeOverrides) == "table" then
                if not keybindOverrides[overrideType] then
                    keybindOverrides[overrideType] = {}
                end

                for identifier, keybind in pairs(typeOverrides) do
                    keybindOverrides[overrideType][identifier] = keybind
                    changesCount = changesCount + 1
                end
            end
        end

        if changesCount > 0 then
            self:SetSetting("char", "keybindOverrides", keybindOverrides)
            self:UpdateAllKeybinds()
            NAG:SendMessage("NAG_KEYBIND_SETTING_CHANGED", "batch", overrides)
        end
    end
end

-- Debug UI for KeybindManager
function KeybindManager:GetDebugSections()
    local function keybindsSection()
        local lines = {}
        table.insert(lines, "Detected UI: " .. (DetectActiveUI() or "Unknown"))
        table.insert(lines, "\124cffffd700All Keybinds (by type):\124r")
        for _, type in ipairs({ "spell", "item", "macro" }) do
            local bindings = self:GetBindingsByType(type)
            if next(bindings) then
                table.insert(lines, ("%s Bindings:"):format(type))
                for id, data in pairs(bindings) do
                    table.insert(lines, format("  %s (%s): %s", data.name or id, id, data.binding or "<none>"))
                end
            end
        end
        return lines
    end
    local function actionSlotsSection()
        local lines = {}
        table.insert(lines, "\124cffffd700Action Slot Assignments:\124r")
        local ASM = NAG:GetModule("ActionSlotManager")
        if ASM and ASM.Actions then
            for slot, action in pairs(ASM.Actions) do
                if action then
                    table.insert(lines,
                        format("Slot %d: %s %s (%s) | Keybind: %s", slot, action.Type or "?", action.ID or "?",
                            action.Text or "", action.HotKey or "<none>"))
                end
            end
        end
        return lines
    end
    local function stanceBarSection()
        local lines = {}
        table.insert(lines, "\124cffffd700Stance Bar Assignments:\124r")
        local activeUI = DetectActiveUI()
        local config = self.ButtonConfig[activeUI]
        if config and config["stance"] then
            local stanceCfg = config["stance"]
            for i = 1, (stanceCfg.maxButtons or 10) do
                local btnName = format("%s%d", stanceCfg.buttonName, i)
                local binding = format(stanceCfg.bindingFormat, i)
                local key = self:FormatKeybind(GetBindingKey(binding))
                table.insert(lines, format("%s: %s", btnName, key or "<none>"))
            end
        else
            table.insert(lines, "No stance bar config for UI: " .. tostring(activeUI))
        end
        return lines
    end
    local function overridesSection()
        local lines = {}
        table.insert(lines, "\124cffffd700Current Keybind Overrides:\124r")
        local keybindOverrides = self.db.char.keybindOverrides
        for type, tbl in pairs(keybindOverrides) do
            if next(tbl) then
                table.insert(lines, type .. ":")
                for id, key in pairs(tbl) do
                    table.insert(lines, format("  %s: %s", id, key))
                end
            end
        end
        return lines
    end
    return {
        { header = "Keybinds",     dataFn = keybindsSection },
        { header = "Action Slots", dataFn = actionSlotsSection },
        { header = "Stance Bar",   dataFn = stanceBarSection },
        { header = "Overrides",    dataFn = overridesSection },
    }
end

function KeybindManager:GetDebugControls()
    return {
        {
            type = "button",
            text = "Force Rescan",
            width = 120,
            onClick = function()
                self:ScanAllActions()
                self:UpdateAllKeybinds()
                if self.debugFrame and self.debugFrame.UpdateDebugFrame then
                    self.debugFrame:UpdateDebugFrame()
                end
            end
        },
        {
            type = "button",
            text = "Refresh",
            width = 80,
            onClick = function()
                if self.debugFrame and self.debugFrame.UpdateDebugFrame then
                    self.debugFrame:UpdateDebugFrame()
                end
            end
        }
    }
end

function KeybindManager:ShowDebugFrame()
    -- Check if AceGUI is available before trying to show debug frame
    if not ns.AceGUI then
        self:Error("ShowDebugFrame failed: AceGUI not available")
        return
    end

    local success, err = pcall(function()
        ns.DebugFrameUtil:ShowDebugFrame(self, {
            title = "Keybind Manager Debug",
            sections = function() return self:GetDebugSections() end,
            customControls = self:GetDebugControls(),
            refreshInterval = 1.0,
        })
    end)

    if not success then
        self:Error("ShowDebugFrame failed: " .. tostring(err))
    end
end

