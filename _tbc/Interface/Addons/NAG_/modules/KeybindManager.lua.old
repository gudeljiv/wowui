--- @class ActionSlotManager
local ActionSlotManager = NAG:CreateModule("ActionSlotManager", asmDefaults, asmMixins)
ns.ActionSlotManager = ActionSlotManager

-- ActionSlotManager module state
-- ActionSlotManager.Actions is the source of truth for action bar data
ActionSlotManager.Actions = {}
ActionSlotManager.ActionSlotsBy = { spell = {}, item = {}, macro = {}, text = {}, texture = {} }
ActionSlotManager.assignedSlots = {}
ActionSlotManager.MacroBoundSpells = {}
ActionSlotManager.MacroBoundItems = {}
ActionSlotManager.overlayDragMode = false
ActionSlotManager.overlayDragHandles = {}

-- Cache variables for ActionSlotManager
local spellNameToIDCache_ASM = {}
local spellCacheExpiry_ASM = 0
local SPELL_CACHE_DURATION_ASM = 30
local keybindCache_ASM = {}
local lastActionSlotUpdate_ASM = 0
local KEYBIND_CACHE_DURATION_ASM = 60
local actionSlotChangeTimestamp_ASM = 0
local actionSlotsActuallyChanged_ASM = false
local lastActionSlotChangeTime_ASM = 0
local MINIMUM_CHANGE_INTERVAL_ASM = 0.1
local cacheHits_ASM = 0
local cacheMisses_ASM = 0
local TIMER_NAMES_ASM = {
    CACHE_CLEANUP = "cacheCleanup",
    KEYBIND_SYNC = "keybindSync"  -- Debounced timer for KeybindManager sync
}

-- ============================ HELPER FUNCTIONS ============================


--- Get spell ID by name, with caching and spellbook lookup
--- @param spellName string The spell name to look up
--- @return number|nil The spell ID, or nil if not found
local function GetSpellIDByName_ASM(spellName)
    if not spellName or type(spellName) ~= "string" then
        return nil
    end
    local currentTime = GetTime()
    if currentTime < spellCacheExpiry_ASM and spellNameToIDCache_ASM[spellName] then
        return spellNameToIDCache_ASM[spellName]
    end
    if currentTime >= spellCacheExpiry_ASM then
        wipe(spellNameToIDCache_ASM)
        spellCacheExpiry_ASM = currentTime + SPELL_CACHE_DURATION_ASM
    end
    if SpellbookManager_ASM.GetSpellID then
        local spellID = SpellbookManager_ASM:GetSpellID(spellName)
        if spellID then
            spellNameToIDCache_ASM[spellName] = spellID
            return spellID
        end
    end
    local spellInfo = WoWAPI.GetSpellInfo(spellName)
    local fallbackSpellID = spellInfo and spellInfo.spellID
    if fallbackSpellID then
        spellNameToIDCache_ASM[spellName] = fallbackSpellID
        return fallbackSpellID
    end
    return nil
end

--- Resolve a spell ID, handling weapon-dependent spells
--- @param spellID number|string The spell ID or spell name
--- @return number|nil The resolved spell ID, or nil if not found
local function ResolveSpellID_ASM(spellID)
    if not spellID then return nil end
    if type(spellID) == "number" then return spellID end
    if type(spellID) == "string" then
        local numericID = tonumber(spellID)
        if numericID then return numericID end
        return GetSpellIDByName_ASM(spellID)
    end
    return nil
end

-- ============================ ACTION SLOT MANAGEMENT ============================

function ActionSlotManager:ClearAssignedSlots()
    wipe(self.assignedSlots)
end

function ActionSlotManager:MarkSlotAsAssigned(slot)
    self.assignedSlots[slot] = true
end

function ActionSlotManager:IsSlotAssigned(slot)
    return self.assignedSlots[slot] == true
end

function ActionSlotManager:GetCommandName(ActionSlot)
    local activeUI = DetectActiveUI()
    local buttonConfig = KeybindManager.ButtonConfig[activeUI]
    if not buttonConfig then
        buttonConfig = KeybindManager.ButtonConfig[SUPPORTED_UIS.BLIZZARD]
    end

    -- Check if this is a stance bar slot (73-120)
    if ActionSlot >= 73 and ActionSlot <= 120 then
        local _, playerClass = UnitClass("player")
        local stanceNumber = GetStanceNumber()

        if stanceNumber and stanceNumber > 0 then
            local bonusBarStart = 73 + ((stanceNumber - 1) * 12)
            local bonusBarEnd = bonusBarStart + 11

            -- Check if this slot is in the current active stance bar range
            if ActionSlot >= bonusBarStart and ActionSlot <= bonusBarEnd then
                -- For Warriors/Rogues/Druids in stance, stance bars replace main bar - map to bar 1
                if playerClass == "ROGUE" or playerClass == "DRUID" or playerClass == "WARRIOR" then
                    local mainBarSlot = (ActionSlot - bonusBarStart) + 1
                    return format("ACTIONBUTTON%d", mainBarSlot)
                end

                -- For Monks, use the actual stance bar binding format
                if playerClass == "MONK" then
                    local stanceConfig = buttonConfig["stance"]
                    if stanceConfig and stanceConfig.bindingFormat then
                        local stanceButtonNum = ((ActionSlot - bonusBarStart) % 12) + 1
                        return format(stanceConfig.bindingFormat, stanceButtonNum)
                    end
                end
            else
                -- Slot is in a stance bar but NOT the current active stance
                -- For Warriors/Rogues/Druids, inactive stance bars are not accessible - return nil
                if playerClass == "ROGUE" or playerClass == "DRUID" or playerClass == "WARRIOR" then
                    return nil
                end

                -- For Monks, inactive stance bars can still be accessed, so use stance bar format
                if playerClass == "MONK" then
                    local stanceConfig = buttonConfig["stance"]
                    if stanceConfig and stanceConfig.bindingFormat then
                        local stanceButtonNum = ((ActionSlot - 73) % 12) + 1
                        return format(stanceConfig.bindingFormat, stanceButtonNum)
                    end
                end
            end
        end
    end

    -- Regular action bar slot handling
    local barIndex = math.ceil(ActionSlot / 12)
    local buttonSlot = ActionSlot % 12
    if buttonSlot == 0 then buttonSlot = 12 end
    local config = buttonConfig[barIndex]
    if not config then return nil end
    local bindingFormat = config[2]
    if not bindingFormat then return nil end
    local actualButtonSlot = buttonSlot
    if activeUI == SUPPORTED_UIS.DOMINOS and bindingFormat and bindingFormat:find("CLICK") then
        local barOffset = (barIndex - 1) * 12
        actualButtonSlot = buttonSlot + barOffset
    end
    return format(bindingFormat, actualButtonSlot)
end

-- Simplified bar info function
local function GetBarInfo_ASM(ActionSlot)
    ActionSlot = tonumber(ActionSlot) or ActionSlot
    local BarIndex = math.ceil(ActionSlot / 12)
    local BarSlot = ActionSlot % 12
    if BarSlot == 0 then BarSlot = 12 end
    return BarIndex, BarSlot
end

local function AddActionSlotsByValue_ASM(Type, Identifier, ActionSlot)
    -- Ensure the type table exists
    if not ActionSlotManager.ActionSlotsBy[Type] then
        ActionSlotManager.ActionSlotsBy[Type] = {}
    end

    local ActionSlots = ActionSlotManager.ActionSlotsBy[Type][Identifier]
    if not ActionSlots then
        ActionSlots = {}
        ActionSlotManager.ActionSlotsBy[Type][Identifier] = ActionSlots
    end
    -- CRITICAL: Check for duplicates before adding to prevent stale entries
    for _, existingSlot in ipairs(ActionSlots) do
        if existingSlot == ActionSlot then
            return
        end
    end
    tinsert(ActionSlots, ActionSlot)
end

local function RemoveActionSlotsByValue_ASM(Type, Identifier, ActionSlot)
    if not ActionSlotManager.ActionSlotsBy[Type] then
        return
    end
    local ActionSlots = ActionSlotManager.ActionSlotsBy[Type][Identifier]
    if ActionSlots then
        for i, v in ipairs(ActionSlots) do
            if v == ActionSlot then
                tremove(ActionSlots, i)
                break
            end
        end
    end
end

local function ClearAction_ASM(ActionSlot)
    local PrevAction = ActionSlotManager.Actions[ActionSlot]
    if not PrevAction then return end
    local ActionType, ActionID = PrevAction.Type, PrevAction.ID
    local ActionText = PrevAction.Text
    local ActionTexture = PrevAction.Texture
    if ActionTexture then RemoveActionSlotsByValue_ASM("texture", ActionTexture, ActionSlot) end
    if ActionText then RemoveActionSlotsByValue_ASM("text", ActionText, ActionSlot) end
    if ActionID then
        if ActionType == "spell" then
            RemoveActionSlotsByValue_ASM("spell", ActionID, ActionSlot)
        elseif ActionType == "item" then
            RemoveActionSlotsByValue_ASM("item", ActionID, ActionSlot)
        elseif ActionType == "macro" then
            RemoveActionSlotsByValue_ASM("macro", ActionID, ActionSlot)
            if ActionSlotManager.MacroBoundSpells then
                for spellId, macroId in pairs(ActionSlotManager.MacroBoundSpells) do
                    if macroId == ActionID then
                        ActionSlotManager.MacroBoundSpells[spellId] = nil
                    end
                end
            end
            if ActionSlotManager.MacroBoundItems then
                for itemId, macroId in pairs(ActionSlotManager.MacroBoundItems) do
                    if macroId == ActionID then
                        ActionSlotManager.MacroBoundItems[itemId] = nil
                    end
                end
            end
        end
    end
    ActionSlotManager.Actions[ActionSlot] = nil
end

local function UpdateAction_ASM(ActionSlot)
    if not ActionSlot or ActionSlot <= 0 or ActionSlot > 120 then return end

    local oldAction = ActionSlotManager.Actions[ActionSlot]
    local oldActionID = oldAction and oldAction.ID
    local oldActionType = oldAction and oldAction.Type
    ClearAction_ASM(ActionSlot)

    if not HasAction(ActionSlot) then
        if oldActionID then
            ActionSlotManager:MarkActionSlotsChanged()
        end
        return
    end
    local ActionType, ActionID, ActionSubType = GetActionInfo(ActionSlot)

    -- CRITICAL: When using Dominos, WoW's default bars are hidden but still exist.
    -- GetActionInfo() queries WoW's hidden bars, not Dominos' visible bars.
    -- Solution: After getting action info, verify a visible button uses this slot before adding to ActionSlotsBy.
    local activeUI = DetectActiveUI()
    local shouldTrackAction = true
    if activeUI == SUPPORTED_UIS.DOMINOS and ActionID then
        local foundButton = false

        -- Search all possible button frames to see if any visible button uses this action slot
        -- Check ActionButton (bar 1)
        for i = 1, 12 do
            local button = _G["ActionButton" .. i]
            if button and button:IsVisible() and button.action == ActionSlot then
                foundButton = true
                break
            end
        end

        -- Check MultiBar buttons (bars 3-6)
        if not foundButton then
            for i = 1, 12 do
                local buttons = {
                    _G["MultiBarRightButton" .. i],
                    _G["MultiBarLeftButton" .. i],
                    _G["MultiBarBottomRightButton" .. i],
                    _G["MultiBarBottomLeftButton" .. i]
                }
                for _, button in ipairs(buttons) do
                    if button and button:IsVisible() and button.action == ActionSlot then
                        foundButton = true
                        break
                    end
                end
                if foundButton then break end
            end
        end

        -- Check DominosActionButton (bars 2, 7-10, and potentially bar 1)
        if not foundButton then
            for i = 1, 120 do
                local button = _G["DominosActionButton" .. i]
                if button and button:IsVisible() and button.action == ActionSlot then
                    foundButton = true
                    break
                end
            end
        end

        -- Only track this action if a visible button uses this slot
        shouldTrackAction = foundButton
    end


    if oldActionID ~= ActionID or oldActionType ~= ActionType then
        ActionSlotManager:MarkActionSlotsChanged()
    end
    if ActionID and shouldTrackAction then
        if ActionType == "spell" then
            AddActionSlotsByValue_ASM("spell", ActionID, ActionSlot)
        elseif ActionType == "item" then
            AddActionSlotsByValue_ASM("item", ActionID, ActionSlot)
        elseif ActionType == "macro" then
            AddActionSlotsByValue_ASM("macro", ActionID, ActionSlot)
            local macroSpellId = GetMacroSpell(ActionID)
            local macroItemId = GetMacroItem(ActionID)
            if macroSpellId then
                AddActionSlotsByValue_ASM("spell", macroSpellId, ActionSlot)
                if not ActionSlotManager.MacroBoundSpells then
                    ActionSlotManager.MacroBoundSpells = {}
                end
                ActionSlotManager.MacroBoundSpells[macroSpellId] = ActionID
            end
            if macroItemId and shouldTrackAction then
                AddActionSlotsByValue_ASM("item", macroItemId, ActionSlot)
                if not ActionSlotManager.MacroBoundItems then
                    ActionSlotManager.MacroBoundItems = {}
                end
                ActionSlotManager.MacroBoundItems[macroItemId] = ActionID
            end
        end
    end
    local ActionTexture = GetActionTexture(ActionSlot)
    if ActionTexture and shouldTrackAction then AddActionSlotsByValue_ASM("texture", ActionTexture, ActionSlot) end
    local ActionText = GetActionText(ActionSlot)
    if ActionText and shouldTrackAction then AddActionSlotsByValue_ASM("text", ActionText, ActionSlot) end
    local CommandName = ActionSlotManager:GetCommandName(ActionSlot)
    local RawHotKey = (CommandName and GetBindingKey(CommandName)) or nil
    local ActionHotKey = RawHotKey and ActionSlotManager:FormatKeybind(RawHotKey) or nil
    ActionSlotManager.Actions[ActionSlot] = {
        Slot = ActionSlot,
        Type = ActionType,
        ID = ActionID,
        SubType = ActionSubType,
        Texture = ActionTexture,
        Text = ActionText,
        CommandName = CommandName,
        HotKey = ActionHotKey
    }
end

-- Shared FormatKeybind for ActionSlotManager
function ActionSlotManager:FormatKeybind(key)
    return KeybindManager:FormatKeybind(key)
end

-- ============================ LIFECYCLE METHODS ============================

function ActionSlotManager:ModuleInitialize()
    SpellbookManager_ASM = NAG:GetModule("SpellbookManager")
    TimerManager_ASM = NAG:GetModule("TimerManager")
    ResetManager = NAG:GetModule("ResetManager")
    DisplayManager = NAG:GetModule("DisplayManager")
    OptionsFactory = NAG:GetModule("OptionsFactory")

    self:ClearAssignedSlots()
    for i = 1, 120 do
        UpdateAction_ASM(i)
    end

    local macroCount = 0
    for _ in pairs(ActionSlotManager.ActionSlotsBy.macro) do
        macroCount = macroCount + 1
    end
    self:Info("ActionSlotManager: Initialization complete - detected " .. macroCount .. " macros in action slots")

    ResetManager:RegisterPreservationGroup("actionSlotManager", {
        name = L["preservationActionslotmanager"] or "Action Slot Manager Settings",
        description = L["preservationActionslotmanagerDescription"] or "Preserve action slot manager settings including legacy and modern display configurations",
        settings = {
            global = { "keybindFont", "whitelist", "legacy", "modern" }
        },
        alwaysPreserve = false
    }, "ActionSlotManager")

    ResetManager:RegisterPreservationGroup("uiLayout", {
        name = L["preservationUilayout"] or "UI Layout Settings",
        description = L["preservationUilayoutDescription"] or "Preserve UI layout and display settings across multiple modules",
        settings = {
            global = { "whitelist", "legacy", "modern" }
        },
        alwaysPreserve = false
    }, "ActionSlotManager")
end

function ActionSlotManager:ModuleEnable()
    self:Info("ActionSlotManager: Module enabled and ready to receive messages")
    self:Debug("ActionSlotManager: Module enabled")
    self:CreateTimer(TimerManager_ASM.Categories.CORE, TIMER_NAMES_ASM.CACHE_CLEANUP, function()
        self:CleanupCache_ASM()
    end, 300, true)
    self:Info("ActionSlotManager: Cache cleanup timer started")
end

function ActionSlotManager:ModuleDisable()
    self:Debug("ActionSlotManager: Module disabled, cleaning up")
    self:CancelTimer(TimerManager_ASM.Categories.CORE, TIMER_NAMES_ASM.CACHE_CLEANUP)
    -- Clean up debounced keybind sync timer (safe to call even if timer doesn't exist)
    TimerManager_ASM:Cancel(TimerManager_ASM.Categories.CORE, TIMER_NAMES_ASM.KEYBIND_SYNC)
    -- KeybindManager manages all frames - no cleanup needed here
    self.Actions = {}
    self.ActionSlotsBy = { spell = {}, item = {}, macro = {}, text = {}, texture = {} }
end

-- ============================ CORE KEYBIND GETTERS ============================

local function FindAction_ASM(Type, Identifier)
    -- Type should already be lowercase (all callers use lowercase)
    local ActionSlots = ActionSlotManager.ActionSlotsBy[Type] and ActionSlotManager.ActionSlotsBy[Type][Identifier]
    if not ActionSlots then return nil end

    local _, playerClass = UnitClass("player")
    local stanceNumber = GetStanceNumber()

    if stanceNumber and stanceNumber > 0 then
        local bonusBarStart = 73 + ((stanceNumber - 1) * 12)
        local bonusBarEnd = bonusBarStart + 11

        -- For Monks, visual bars don't swap, so prioritize regular bars over stance bars
        -- For other classes, stance bars replace the main bar, so check stance bars first
        if playerClass == "MONK" then
            -- Check regular bars first for Monks
            -- First check main bar (slots 1-12)
            for _, slot in pairs(ActionSlots) do
                if slot <= 12 and not ActionSlotManager:IsSlotAssigned(slot) then
                    local action = ActionSlotManager.Actions[slot]
                    -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                    -- action.Type is always lowercase from WoW API
                    if action and action.ID == Identifier and (action.Type or "") == Type then
                        local commandName = ActionSlotManager:GetCommandName(slot)
                        if commandName then
                            local rawKeybind = GetBindingKey(commandName)
                            action.HotKey = ActionSlotManager:FormatKeybind(rawKeybind)
                            ActionSlotManager:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end
            end

            -- Then check other bars (excluding stance bars 73-120)
            for _, slot in pairs(ActionSlots) do
                if slot > 12 and slot < 73 and not ActionSlotManager:IsSlotAssigned(slot) then
                    local action = ActionSlotManager.Actions[slot]
                    -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                    -- action.Type is always lowercase from WoW API
                    if action and action.ID == Identifier and (action.Type or "") == Type then
                        local commandName = ActionSlotManager:GetCommandName(slot)
                        if commandName then
                            action.HotKey = ActionSlotManager:FormatKeybind(GetBindingKey(commandName))
                            ActionSlotManager:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end
            end

            -- Finally check stance bars for Monks (use actual keybind, not mapped to bar 1)
            for _, slot in pairs(ActionSlots) do
                if slot >= bonusBarStart and slot <= bonusBarEnd and not ActionSlotManager:IsSlotAssigned(slot) then
                    local action = ActionSlotManager.Actions[slot]
                    -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                    -- action.Type is always lowercase from WoW API
                    if action and action.ID == Identifier and (action.Type or "") == Type then
                        local commandName = ActionSlotManager:GetCommandName(slot)
                        if commandName then
                            action.HotKey = ActionSlotManager:FormatKeybind(GetBindingKey(commandName))
                            ActionSlotManager:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end
            end
        else
            -- For Warriors/Rogues/Druids, stance bars replace main bar, so check stance bars first
            for _, slot in pairs(ActionSlots) do
                if slot >= bonusBarStart and slot <= bonusBarEnd and not ActionSlotManager:IsSlotAssigned(slot) then
                    local action = ActionSlotManager.Actions[slot]
                    -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                    -- action.Type is always lowercase from WoW API
                    if action and action.ID == Identifier and (action.Type or "") == Type then
                        -- GetCommandName now handles stance bars correctly for Warriors/Rogues/Druids
                        local commandName = ActionSlotManager:GetCommandName(slot)
                        if commandName then
                            action.HotKey = ActionSlotManager:FormatKeybind(GetBindingKey(commandName))
                            ActionSlotManager:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end
            end
            for _, slot in pairs(ActionSlots) do
                if slot <= 12 and not ActionSlotManager:IsSlotAssigned(slot) then
                    local action = ActionSlotManager.Actions[slot]
                    -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                    -- action.Type is always lowercase from WoW API
                    if action and action.ID == Identifier and (action.Type or "") == Type then
                        local commandName = ActionSlotManager:GetCommandName(slot)
                        if commandName then
                            local rawKeybind = GetBindingKey(commandName)
                            action.HotKey = ActionSlotManager:FormatKeybind(rawKeybind)
                            ActionSlotManager:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end
            end
            for _, slot in pairs(ActionSlots) do
                if slot > 12 and slot < 73 and not ActionSlotManager:IsSlotAssigned(slot) then
                    local action = ActionSlotManager.Actions[slot]
                    -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                    -- action.Type is always lowercase from WoW API
                    if action and action.ID == Identifier and (action.Type or "") == Type then
                        local commandName = ActionSlotManager:GetCommandName(slot)
                        if commandName then
                            action.HotKey = ActionSlotManager:FormatKeybind(GetBindingKey(commandName))
                            ActionSlotManager:MarkSlotAsAssigned(slot)
                            return action
                        end
                    end
                end
            end
        end
    else
        local bestAction = nil
        local bestKeybind = nil
        for _, slot in pairs(ActionSlots) do
            if slot <= 120 and not ActionSlotManager:IsSlotAssigned(slot) then
                local action = ActionSlotManager.Actions[slot]
                -- CRITICAL: Validate that the action actually matches the requested spell/item/macro
                -- action.Type is always lowercase from WoW API
                if action and action.ID == Identifier and (action.Type or "") == Type then
                    local commandName = ActionSlotManager:GetCommandName(slot)
                    if commandName then
                        local rawKeybind = GetBindingKey(commandName)
                        if rawKeybind then
                            action.HotKey = ActionSlotManager:FormatKeybind(rawKeybind)
                            ActionSlotManager:MarkSlotAsAssigned(slot)
                            if not bestKeybind then
                                bestAction = action
                                bestKeybind = rawKeybind
                            end
                        end
                    end
                end
            end
        end
        return bestAction
    end
    return nil
end

function ActionSlotManager:GetHotKeyForSpell(spellID)
    local resolvedSpellID = ResolveSpellID_ASM(spellID)
    if not resolvedSpellID then return nil end

    local whitelistKeybind = self:GetWhitelistHotKey("spell", resolvedSpellID)
    if whitelistKeybind then return whitelistKeybind end

    local cacheKey = format("spell:%s", tostring(resolvedSpellID))
    if self:IsKeybindCacheValid() and keybindCache_ASM[cacheKey] then
        cacheHits_ASM = cacheHits_ASM + 1
        return keybindCache_ASM[cacheKey]
    end

    cacheMisses_ASM = cacheMisses_ASM + 1

    if self.MacroBoundSpells and self.MacroBoundSpells[resolvedSpellID] then
        local macroKeybind = self:GetHotKeyForMacro(self.MacroBoundSpells[resolvedSpellID])
        if self:IsKeybindCacheValid() then
            keybindCache_ASM[cacheKey] = macroKeybind
        end
        return macroKeybind
    end

    local spellInfo = WoWAPI.GetSpellInfo(resolvedSpellID)
    local spellName = spellInfo and spellInfo.name
    if not spellName then return nil end

    local currentSpellbookID = GetSpellIDByName_ASM(spellName)
    if not currentSpellbookID then return nil end

    self:ClearAssignedSlots()
    local action = FindAction_ASM("spell", currentSpellbookID)
    local keybind = action and action.HotKey or nil

    if self:IsKeybindCacheValid() then
        keybindCache_ASM[cacheKey] = keybind
    end

    return keybind
end

function ActionSlotManager:GetHotKeyForItem(itemID)
    local whitelistKeybind = self:GetWhitelistHotKey("item", itemID)
    if whitelistKeybind then return whitelistKeybind end

    local cacheKey = format("item:%s", tostring(itemID))
    if self:IsKeybindCacheValid() and keybindCache_ASM[cacheKey] then
        cacheHits_ASM = cacheHits_ASM + 1
        return keybindCache_ASM[cacheKey]
    end

    cacheMisses_ASM = cacheMisses_ASM + 1

    if self.MacroBoundItems and self.MacroBoundItems[itemID] then
        local macroKeybind = self:GetHotKeyForMacro(self.MacroBoundItems[itemID])
        if self:IsKeybindCacheValid() then
            keybindCache_ASM[cacheKey] = macroKeybind
        end
        return macroKeybind
    end

    self:ClearAssignedSlots()
    local action = FindAction_ASM("item", itemID)
    local keybind = action and action.HotKey or nil

    if self:IsKeybindCacheValid() then
        keybindCache_ASM[cacheKey] = keybind
    end

    return keybind
end

function ActionSlotManager:GetHotKeyForMacro(macroID)
    local whitelistKeybind = self:GetWhitelistHotKey("macro", macroID)
    if whitelistKeybind then return whitelistKeybind end

    local cacheKey = format("macro:%s", tostring(macroID))
    if self:IsKeybindCacheValid() and keybindCache_ASM[cacheKey] then
        cacheHits_ASM = cacheHits_ASM + 1
        return keybindCache_ASM[cacheKey]
    end

    cacheMisses_ASM = cacheMisses_ASM + 1

    self:ClearAssignedSlots()
    local action = FindAction_ASM("macro", macroID)
    local keybind = action and action.HotKey or nil

    if self:IsKeybindCacheValid() then
        keybindCache_ASM[cacheKey] = keybind
    end

    return keybind
end

function ActionSlotManager:GetHotKeyForText(text)
    local action = FindAction_ASM("text", text)
    return action and action.HotKey or nil
end

function ActionSlotManager:GetHotKeyForTexture(textureID)
    local action = FindAction_ASM("texture", textureID)
    return action and action.HotKey or nil
end

function ActionSlotManager:ResolveSpellID(spellID)
    return ResolveSpellID_ASM(spellID)
end

function ActionSlotManager:GetSpellIDByName(spellName)
    return GetSpellIDByName_ASM(spellName)
end

-- ============================ CACHE MANAGEMENT ============================

function ActionSlotManager:ClearSpellCache()
    wipe(spellNameToIDCache_ASM)
    spellCacheExpiry_ASM = 0
    self:Debug("Spell name to ID cache cleared")
end

function ActionSlotManager:ClearKeybindCache()
    wipe(keybindCache_ASM)
    lastActionSlotUpdate_ASM = 0
    self:Debug("Keybind cache cleared")
end

function ActionSlotManager:MarkActionSlotsChanged()
    local currentTime = GetTime()
    if currentTime - lastActionSlotChangeTime_ASM >= MINIMUM_CHANGE_INTERVAL_ASM then
        actionSlotChangeTimestamp_ASM = currentTime
        lastActionSlotChangeTime_ASM = currentTime
        actionSlotsActuallyChanged_ASM = true
        self:ClearKeybindCache()
        self:Debug("Action slots changed - keybind cache invalidated")
    else
        -- Mark as changed but don't log (throttled - will be processed when interval expires)
        actionSlotsActuallyChanged_ASM = true
    end
end

function ActionSlotManager:IsKeybindCacheValid()
    local currentTime = GetTime()
    if not actionSlotsActuallyChanged_ASM then return true end
    return currentTime - actionSlotChangeTimestamp_ASM < KEYBIND_CACHE_DURATION_ASM
end

function ActionSlotManager:ForceCacheInvalidation()
    actionSlotChangeTimestamp_ASM = GetTime()
    lastActionSlotChangeTime_ASM = GetTime()
    actionSlotsActuallyChanged_ASM = true
    self:ClearKeybindCache()
    self:Debug("Keybind cache force invalidated")
end

function ActionSlotManager:CleanupCache_ASM()
    local currentTime = GetTime()
    local TableUtils = ns.TableUtils
    if TableUtils.Size(keybindCache_ASM) > 100 and currentTime - lastActionSlotUpdate_ASM > 300 then
        self:ClearKeybindCache()
        self:Debug("Cache cleaned up due to size and inactivity")
    end
end

function ActionSlotManager:CreateTimer(category, name, callback, interval, repeating, args)
    return TimerManager_ASM:Create(category, name, callback, interval, repeating, args)
end

function ActionSlotManager:CancelTimer(category, name)
    TimerManager_ASM:Cancel(category, name)
end

function ActionSlotManager:IsTimerActive(category, name)
    return TimerManager_ASM:IsTimerActive(category, name)
end

function ActionSlotManager:ResetCacheChangeTracking()
    actionSlotsActuallyChanged_ASM = false
    lastActionSlotChangeTime_ASM = 0
    self:Debug("Cache change tracking reset")
end

function ActionSlotManager:ResetCachePerformanceTracking()
    cacheHits_ASM = 0
    cacheMisses_ASM = 0
    self:Debug("Cache performance tracking reset")
end

function ActionSlotManager:GetCacheStats()
    local TableUtils = ns.TableUtils
    return {
        keybindCacheSize = TableUtils.Size(keybindCache_ASM),
        spellCacheSize = TableUtils.Size(spellNameToIDCache_ASM),
        actionSlotsChanged = actionSlotsActuallyChanged_ASM,
        lastChangeTime = lastActionSlotChangeTime_ASM,
        cacheValid = self:IsKeybindCacheValid(),
        cacheHits = cacheHits_ASM,
        cacheMisses = cacheMisses_ASM
    }
end

-- ============================ WHITELIST MANAGEMENT ============================

function ActionSlotManager:GetWhitelistHotKey(type, id)
    local whitelist = self.db.global.whitelist
    if whitelist[type] and whitelist[type][id] then
        return whitelist[type][id]
    end
    return nil
end

function ActionSlotManager:WhitelistHotKey(type, id, hotkey)
    if not type or not id then return end
    local whitelist = self.db.global.whitelist
    if not whitelist[type] then
        whitelist[type] = {}
    end
    whitelist[type][id] = hotkey
    self.db.global.whitelist = whitelist
    local KeybindManager = NAG:GetModule("KeybindManager")
    if KeybindManager then
        KeybindManager:UpdateAllKeybinds()
    end
    self:SendMessage("NAG_WHITELIST_CHANGED", type, id, hotkey)
end

function ActionSlotManager:RemoveWhitelistHotKey(type, id)
    if not type or not id then return end
    local whitelist = self.db.global.whitelist
    if whitelist[type] and whitelist[type][id] then
        whitelist[type][id] = nil
        self.db.global.whitelist = whitelist
        local KeybindManager = NAG:GetModule("KeybindManager")
        if KeybindManager then
            KeybindManager:UpdateAllKeybinds()
        end
        self:SendMessage("NAG_WHITELIST_CHANGED", type, id, nil)
    end
end

function ActionSlotManager:GetWhitelistEntries(type)
    local whitelist = self.db.global.whitelist
    return whitelist[type] or {}
end

function ActionSlotManager:SetMultipleWhitelistOverrides(overrides)
    if not overrides or type(overrides) ~= "table" then return end
    local whitelist = self.db.global.whitelist
    local changesCount = 0
    for overrideType, typeOverrides in pairs(overrides) do
        if type(typeOverrides) == "table" then
            if not whitelist[overrideType] then
                whitelist[overrideType] = {}
            end
            for identifier, hotkey in pairs(typeOverrides) do
                whitelist[overrideType][identifier] = hotkey
                changesCount = changesCount + 1
            end
        end
    end
    if changesCount > 0 then
        self.db.global.whitelist = whitelist
        local KeybindManager = NAG:GetModule("KeybindManager")
        if KeybindManager then
            KeybindManager:UpdateAllKeybinds()
        end
        self:SendMessage("NAG_WHITELIST_BATCH_CHANGED", overrides)
    end
end

function ActionSlotManager:ClearWhitelist(type)
    local whitelist = self.db.global.whitelist
    if type then
        if whitelist[type] then
            whitelist[type] = {}
            self.db.global.whitelist = whitelist
            local KeybindManager = NAG:GetModule("KeybindManager")
            if KeybindManager then
                KeybindManager:UpdateAllKeybinds()
            end
            self:SendMessage("NAG_WHITELIST_CLEARED", type)
        end
    else
        whitelist = {
            spell = {},
            item = {},
            macro = {},
            text = {},
            texture = {}
        }
        self.db.global.whitelist = whitelist
        local KeybindManager = NAG:GetModule("KeybindManager")
        if KeybindManager then
            KeybindManager:UpdateAllKeybinds()
        end
        self:SendMessage("NAG_WHITELIST_CLEARED", "all")
    end
end

function ActionSlotManager:HandleWhitelistCommand(input)
    if not input or input == "" then
        self:Print("NAG ActionSlotManager Whitelist Manager is active.")
        self:Print("Usage: /nagdebug config whitelist [add|remove|list|clear] [type] [id] [keybind]")
        self:Print("Short alias: /wl [add|remove|list|clear] [type] [id] [keybind]")
        return
    end

    local args = { strsplit(" ", input) }
    local command = strlower(args[1] or "")

    if command == "add" then
        local type = strlower(args[2] or "")
        local id = tonumber(args[3])
        local keybind = args[4]
        if not type or not id or not keybind then
            self:Error("Usage: /wl add [spell|item|macro] [id] [keybind]")
            return
        end
        if type ~= "spell" and type ~= "item" and type ~= "macro" then
            self:Error("Type must be 'spell', 'item', or 'macro'")
            return
        end
        self:WhitelistHotKey(type, id, keybind)
        if self.debug then self:Info("Added %s whitelist override: %d -> %s", type, id, keybind) end
    elseif command == "remove" then
        local type = strlower(args[2] or "")
        local id = tonumber(args[3])
        if not type or not id then
            self:Error("Usage: /wl remove [spell|item|macro] [id]")
            return
        end
        if type ~= "spell" and type ~= "item" and type ~= "macro" then
            self:Error("Type must be 'spell', 'item', or 'macro'")
            return
        end
        self:RemoveWhitelistHotKey(type, id)
        if self.debug then self:Info("Removed %s whitelist override for: %d", strlower(type), id) end
    elseif command == "list" then
        local whitelist = self.db.global.whitelist
        local hasEntries = false
        self:Print("=== Current Whitelist Overrides ===")
        for type, entries in pairs(whitelist) do
            if next(entries) then
                hasEntries = true
                self:Print(format("%s:", type))
                for id, keybind in pairs(entries) do
                    local name = "Unknown"
                    if type == "spell" then
                        local spellInfo = WoWAPI.GetSpellInfo(id)
                        name = spellInfo and spellInfo.name or "Unknown"
                    elseif type == "item" then
                        name = WoWAPI.GetItemInfo(id) or "Unknown"
                    elseif type == "macro" then
                        local macroName = GetMacroInfo(id)
                        name = macroName or "Unknown"
                    end
                    self:Print(format("  %s (%d): %s", name, id, keybind))
                end
            end
        end
        if not hasEntries then
            self:Print("No whitelist overrides found.")
        end
    elseif command == "clear" then
        self:ClearWhitelist()
        self:Info("Cleared all whitelist overrides")
    else
        self:Error("Unknown command: " .. command)
        self:Print("Use /wl or /nagdebug config whitelist for help")
    end
end

-- ============================ EVENT HANDLERS ============================

function ActionSlotManager:SPELLS_CHANGED(event)
    -- Queue until startup complete
    local EventManager = ns.EventManager
    if EventManager and EventManager.currentPhase < ns.StartupPhase.COMPLETE then
        return  -- Event is already queued by EventManager
    end

    self:Info("ActionSlotManager: SPELLS_CHANGED event received")
    self:ClearSpellCache()
    self:MarkActionSlotsChanged()
end

function ActionSlotManager:PLAYER_EQUIPMENT_CHANGED(event, equipmentSlot, hasCurrent)
    self:Info("ActionSlotManager: PLAYER_EQUIPMENT_CHANGED event received - slot: %s, hasCurrent: %s",
        equipmentSlot, tostring(hasCurrent))
    if (equipmentSlot == 16 or equipmentSlot == 17) then
        self:ClearSpellCache()
        self:MarkActionSlotsChanged()
    end
end

function ActionSlotManager:ACTIONBAR_SLOT_CHANGED(event, slot)
    -- Only log in debug mode to reduce spam (many slots can change at once during spec changes)
    if self.debug then
        self:Trace("ActionSlotManager: ACTIONBAR_SLOT_CHANGED event fired for slot: " .. tostring(slot))
    end

    UpdateAction_ASM(slot)

    -- Debounce KeybindManager sync - cancel any pending sync and reschedule
    -- This prevents expensive ScanAllActions() from running for every single slot change
    -- When spec changes, many ACTIONBAR_SLOT_CHANGED events fire in rapid succession
    local KeybindManager = NAG:GetModule("KeybindManager")
    if KeybindManager and KeybindManager.db and KeybindManager.db.global.enableKeybinds then
        -- Cancel any pending sync timer (safe to call even if timer doesn't exist)
        TimerManager_ASM:Cancel(TimerManager_ASM.Categories.CORE, TIMER_NAMES_ASM.KEYBIND_SYNC)

        -- Schedule debounced sync (0.5 second delay allows multiple slot changes to batch)
        TimerManager_ASM:Create(
            TimerManager_ASM.Categories.CORE,
            TIMER_NAMES_ASM.KEYBIND_SYNC,
            function()
                KeybindManager:ScanAllActions()
            end,
            0.5,  -- 0.5 second delay to batch rapid slot changes
            false -- One-time timer
        )
    end
end

function ActionSlotManager:UPDATE_BINDINGS()
    local currentTime = GetTime()
    if currentTime - lastActionSlotChangeTime_ASM < MINIMUM_CHANGE_INTERVAL_ASM then
        return
    end
    self:ClearAssignedSlots()
    for i = 1, 120 do
        if HasAction(i) then
            UpdateAction_ASM(i)
        end
    end
    lastActionSlotChangeTime_ASM = currentTime
    -- Notify KeybindManager to sync
    local KeybindManager = NAG:GetModule("KeybindManager")
    if KeybindManager and KeybindManager.db and KeybindManager.db.global.enableKeybinds then
        KeybindManager:ScanAllActions()
    end
end

function ActionSlotManager:UPDATE_MACROS()
    self:Debug("ActionSlotManager: UPDATE_MACROS event fired - updating all slots")
    self:Debug("ActionSlotManager: Checking for macro changes...")
    self:ClearAssignedSlots()
    for i = 1, 120 do
        UpdateAction_ASM(i)
    end
    -- Notify KeybindManager to sync displays
    local KeybindManager = NAG:GetModule("KeybindManager")
    if KeybindManager and KeybindManager.db and KeybindManager.db.global.enableKeybinds then
        KeybindManager:ScanAllActions()
    end
    self:Debug("ActionSlotManager: Macro update complete")
end

function ActionSlotManager:NAG_SPEC_UPDATED(message)
    self:Info("ActionSlotManager: NAG_SPEC_UPDATED message received")
    self:Debug("ActionSlotManager: Refreshing action slots due to spec change")
    self.Actions = {}
    self.ActionSlotsBy = { spell = {}, item = {}, macro = {}, text = {}, texture = {} }
    for i = 1, 120 do
        UpdateAction_ASM(i)
    end
    local KeybindManager = NAG:GetModule("KeybindManager")
    if KeybindManager then
        KeybindManager:UpdateAllKeybinds()
    end
    self:ResetCacheChangeTracking()
    self:Debug("ActionSlotManager: Action slots refreshed after spec change")
end

function ActionSlotManager:NAG_KEYBIND_SETTING_CHANGED(message, setting, value)
    self:Info("ActionSlotManager: NAG_KEYBIND_SETTING_CHANGED message received - setting: " ..
        tostring(setting) .. ", value: " .. tostring(value))
    local KeybindManager = NAG:GetModule("KeybindManager")
    if KeybindManager then
        KeybindManager:UpdateAllKeybinds()
    end
end

-- ============================ FRAME MANAGEMENT ============================
-- Frame management has been consolidated into KeybindManager
-- ActionSlotManager now focuses solely on data management (action slots, command names, whitelist)

function ActionSlotManager:SetOverlayDragMode(enabled)
    self.overlayDragMode = enabled
    local groupFrames = DisplayManager.groupFrames or {}
    for group, handle in pairs(self.overlayDragHandles) do
        if handle and handle:IsShown() then
            handle:Hide()
            handle:SetParent(nil)
        end
        self.overlayDragHandles[group] = nil
    end
    if enabled then
        for group, frame in pairs(groupFrames) do
            if frame and frame:IsShown() then
                local anchor = self.db.global.modern.overlayAnchor[group]
                local handle = CreateFrame("Button", nil, frame)
                handle:SetSize(16, 16)
                handle:SetFrameStrata("DIALOG")
                handle:SetFrameLevel(200)
                handle:SetMovable(true)
                handle:EnableMouse(true)
                handle:RegisterForDrag("LeftButton")
                handle:SetPoint(anchor.point or "TOPRIGHT", frame, anchor.point or "TOPRIGHT", anchor.x or -2,
                    anchor.y or -2)
                handle:SetAlpha(0.9)

                local pin = handle:CreateTexture(nil, "ARTWORK")
                pin:SetAllPoints()
                pin:SetTexture("Interface/Buttons/WHITE8X8")
                pin:SetTexCoord(0.25, 0.75, 0.25, 0.75)
                pin:SetVertexColor(1, 0.3, 0.3, 1)
                handle.pin = pin

                local highlight = handle:CreateTexture(nil, "OVERLAY")
                highlight:SetAllPoints()
                highlight:SetTexture("Interface/Buttons/WHITE8X8")
                highlight:SetTexCoord(0.25, 0.75, 0.25, 0.75)
                highlight:SetVertexColor(1, 1, 1, 0.3)
                handle.highlight = highlight

                handle:SetScript("OnDragStart", function(selfBtn)
                    selfBtn:StartMoving()
                end)
                handle:SetScript("OnDragStop", function(selfBtn)
                    selfBtn:StopMovingOrSizing()
                    local ox, oy = select(4, selfBtn:GetPoint())
                    anchor.point = anchor.point or "TOPRIGHT"
                    anchor.x = ox
                    anchor.y = oy
                    ActionSlotManager.db.global.modern.overlayAnchor[group] = anchor
                    ActionSlotManager:RefreshAllKeybindOverlays()
                end)
                handle:SetScript("OnEnter", function(selfBtn)
                    GameTooltip:SetOwner(selfBtn, "ANCHOR_TOP")
                    local groupDisplayName = DisplayManager:GetGroupDisplayName(group) or "Unknown Group"
                    GameTooltip:SetText(
                        format(
                            "Drag to reposition keybind overlay for %s group.\nPosition is shared by all icons in this group.",
                            groupDisplayName), 1, 1, 1)
                    GameTooltip:Show()
                end)
                handle:SetScript("OnLeave", function() GameTooltip:Hide() end)
                handle:Show()
                self.overlayDragHandles[group] = handle
            end
        end
    end
end

function ActionSlotManager:RefreshAllKeybindOverlays()
    for group, frame in pairs(DisplayManager.groupFrames) do
        if frame and frame.iconFrames then
            for _, icon in ipairs(frame.iconFrames) do
                if icon.UpdateKeybindText then icon:UpdateKeybindText() end
            end
        end
    end
end

-- ============================ DEBUG METHODS ============================

function ActionSlotManager:DebugSlot(slot)
    slot = tonumber(slot)
    if not slot or slot < 1 or slot > 120 then
        self:Print("Invalid slot number. Use a number between 1 and 120.")
        return
    end

    local action = ActionSlotManager.Actions[slot]
    local barIndex, barSlot = GetBarInfo_ASM(slot)
    local commandName = ActionSlotManager:GetCommandName(slot)
    local rawHotKey = commandName and GetBindingKey(commandName) or nil

    self:Print("=== Slot " .. slot .. " Debug Info ===")
    self:Print("Bar Index: " .. barIndex)
    self:Print("Bar Slot: " .. barSlot)
    self:Print("Command Name: " .. (commandName or "nil"))
    self:Print("Raw Hotkey: " .. (rawHotKey or "nil"))

    if action then
        self:Print("Action Type: " .. (action.Type or "nil"))
        self:Print("Action ID: " .. (action.ID or "nil"))
        self:Print("Action SubType: " .. (action.SubType or "nil"))
        self:Print("Action Texture: " .. (action.Texture or "nil"))
        self:Print("Action Text: " .. (action.Text or "nil"))
        self:Print("Formatted Hotkey: " .. (action.HotKey or "nil"))
        if action.Type == "spell" and action.ID then
            local spellInfo = WoWAPI.GetSpellInfo(action.ID)
            local spellName = spellInfo and spellInfo.name
            self:Print("Spell Name: " .. (spellName or "Unknown"))
        end
    else
        self:Print("No action found for this slot")
    end
    self:Print("=== End Debug ===")
end

function ActionSlotManager:DebugBar(bar)
    bar = tonumber(bar)
    if not bar or bar < 1 or bar > 10 then
        self:Print("Invalid bar number. Use a number between 1 and 10.")
        return
    end

    self:Print("=== Bar " .. bar .. " Debug Info ===")
    for slot = 1, 120 do
        local barIndex, barSlot = GetBarInfo_ASM(slot)
        if barIndex == bar then
            local action = ActionSlotManager.Actions[slot]
            local commandName = ActionSlotManager:GetCommandName(slot)
            local rawHotKey = commandName and GetBindingKey(commandName) or nil

            self:Print("Slot " .. slot .. " (Bar Slot " .. barSlot .. "):")
            self:Print("  Command: " .. (commandName or "nil"))
            self:Print("  Raw Hotkey: " .. (rawHotKey or "nil"))
            self:Print("  Formatted Hotkey: " .. (action and action.HotKey or "nil"))

            if action and action.Type == "spell" and action.ID then
                local spellInfo = WoWAPI.GetSpellInfo(action.ID)
                local spellName = spellInfo and spellInfo.name
                self:Print("  Spell: " .. (spellName or "Unknown") .. " (ID: " .. action.ID .. ")")
            elseif action and action.Type == "item" and action.ID then
                local itemName = WoWAPI.GetItemInfo(action.ID)
                self:Print("  Item: " .. (itemName or "Unknown") .. " (ID: " .. action.ID .. ")")
            elseif action and action.Type == "macro" and action.ID then
                local macroName = GetMacroInfo(action.ID)
                self:Print("  Macro: " .. (macroName or "Unknown") .. " (ID: " .. action.ID .. ")")
            end
            self:Print("")
        end
    end
    self:Print("=== End Bar Debug ===")
end

function ActionSlotManager:DebugKeybindConflicts(slot)
    if slot then
        self:Print("=== KEYBIND CONFLICT DEBUG FOR SLOT " .. slot .. " ===")
        local action = ActionSlotManager.Actions[slot]
        local commandName = ActionSlotManager:GetCommandName(slot)
        local rawHotKey = commandName and GetBindingKey(commandName) or nil

        self:Print("Primary Command: " .. (commandName or "nil"))
        self:Print("Primary Keybind: " .. (rawHotKey or "nil"))

        if action then
            self:Print("Action Type: " .. (action.Type or "nil"))
            self:Print("Action ID: " .. (action.ID or "nil"))
            self:Print("Final Hotkey: " .. (action.HotKey or "nil"))
            self:Print("Final Command: " .. (action.CommandName or "nil"))
        else
            self:Print("No action data found for this slot")
        end
        self:Print("=== END DEBUG ===")
    else
        self:Print("Usage: /nag debugkeybinds <slot_number>")
    end
end

function ActionSlotManager:DebugMacro(macroID)
    self:Print("=== Macro Debug Info ===")
    if macroID then
        local macroIDNum = tonumber(macroID)
        if not macroIDNum then
            self:Print("Invalid macro ID: " .. macroID)
            return
        end
        self:Print("Debugging macro ID: " .. macroIDNum)
        local macroName = GetMacroInfo(macroIDNum)
        if macroName then
            self:Print("Macro name: " .. macroName)
        else
            self:Print("Macro not found or invalid ID")
        end
        local action = FindAction_ASM("Macro", macroIDNum)
        if action then
            self:Print("Found in action slot: " .. action.Slot)
            self:Print("Hotkey: " .. (action.HotKey or "none"))
            self:Print("Command name: " .. (action.CommandName or "none"))
        else
            self:Print("Not found in action slots")
        end
        local hotkey = self:GetHotKeyForMacro(macroIDNum)
        self:Print("Resolved hotkey: " .. (hotkey or "none"))
    else
        self:Print("=== All Detected Macros ===")
        local macroCount = 0
        for macroID, slots in pairs(ActionSlotManager.ActionSlotsBy.macro) do
            macroCount = macroCount + 1
            local macroName = GetMacroInfo(macroID)
            local action = ActionSlotManager.Actions[slots[1]]
            self:Print("Macro " .. macroID .. " (" .. (macroName or "Unknown") .. "):")
            self:Print("  Slots: " .. table.concat(slots, ", "))
            self:Print("  Hotkey: " .. (action and action.HotKey or "none"))
            self:Print("")
        end
        if macroCount == 0 then
            self:Print("No macros detected in action slots")
        end
    end
    self:Print("=== End Macro Debug ===")
end

function ActionSlotManager:ToggleMacroDebug()
    self.macroDebugMode = not self.macroDebugMode
    if self.macroDebugMode then
        self:Print("Macro debug mode: ENABLED")
    else
        self:Print("Macro debug mode: DISABLED")
    end
end

function ActionSlotManager:DebugMouseSlot()
    local mouseX, mouseY = GetCursorPosition()
    self:Print("=== Mouse Debug Info ===")
    self:Print("Mouse Position: " .. mouseX .. ", " .. mouseY)
    self:Print("=== End Mouse Debug ===")
end

function ActionSlotManager:ListSpellsInSpellbook()
    self:Print("=== Listing All Spells in Spellbook ===")
    if SpellbookManager_ASM.GetAllSpells then
        local allSpells = SpellbookManager_ASM:GetAllSpells()
        local totalSpells = 0
        for spellID, spell in pairs(allSpells or {}) do
            if spell.name and spell.type == "SPELL" then
                self:Print("  " .. spell.name .. " (ID: " .. spellID .. ")")
                totalSpells = totalSpells + 1
            end
        end
        self:Print("Total spells found: " .. totalSpells)
    end
    self:Print("=== End Spellbook List ===")
end

function ActionSlotManager:ShowCacheStats()
    local stats = self:GetCacheStats()
    self:Print("=== Cache Statistics ===")
    self:Print("Keybind Cache Size: " .. stats.keybindCacheSize)
    self:Print("Spell Cache Size: " .. stats.spellCacheSize)
    self:Print("Cache Valid: " .. tostring(stats.cacheValid))
    self:Print("Cache Hit Rate: " .. string.format("%.1f%%", (stats.cacheHits / (stats.cacheHits + stats.cacheMisses) * 100)))
    self:Print("=== End Cache Stats ===")
end

function ActionSlotManager:ShowTimerStatus()
    self:Print("=== Timer Status ===")
    local cacheTimerActive = self:IsTimerActive(TimerManager_ASM.Categories.CORE, TIMER_NAMES_ASM.CACHE_CLEANUP)
    self:Print("Cache Cleanup Timer: " .. (cacheTimerActive and "|cff00ff00Active|r" or "|cffff6666Inactive|r"))
    self:Print("=== End Timer Status ===")
end

function ActionSlotManager:RestartCacheCleanupTimer()
    self:CancelTimer(TimerManager_ASM.Categories.CORE, TIMER_NAMES_ASM.CACHE_CLEANUP)
    self:CreateTimer(TimerManager_ASM.Categories.CORE, TIMER_NAMES_ASM.CACHE_CLEANUP, function()
        self:CleanupCache_ASM()
    end, 300, true)
    self:Info("Cache cleanup timer restarted")
end

function ActionSlotManager:TestMessageHandlers()
    self:Print("=== Testing Message Handlers ===")
    self:SendMessage("NAG_SPEC_UPDATED")
    self:SendMessage("NAG_KEYBIND_SETTING_CHANGED", "testSetting", "testValue")
    self:Print("Test messages sent.")
end

function ActionSlotManager:ShowMessageHandlerInfo()
    self:Print("=== Message Handler Information ===")
    self:Print("Registered Message Handlers:")
    self:Print("  NAG_SPEC_UPDATED")
    self:Print("  NAG_KEYBIND_SETTING_CHANGED")
    self:Print("Module Status:")
    self:Print("  Enabled: " .. (self:IsEnabled() and "Yes" or "No"))
    self:Print("=== End Message Handler Info ===")
end


-- ============================ OPTIONS COMPOSERS ============================

function ActionSlotManager:ui_asm(options, context)
    if options.args and options.args.DisplayManager and options.args.DisplayManager.args and
        options.args.DisplayManager.args.groupControl and options.args.DisplayManager.args.groupControl.args and
        options.args.DisplayManager.args.groupControl.args.groupFramesModern and
        options.args.DisplayManager.args.groupControl.args.groupFramesModern.args then
        local groupKeys = { ns.FRAME_GROUPS.MAIN, ns.FRAME_GROUPS.AOE, ns.FRAME_GROUPS.COOLDOWNS, ns.FRAME_GROUPS.INTERRUPTS, ns.FRAME_GROUPS.DEFENSIVES, ns.FRAME_GROUPS.SEQUENCE }
        for _, groupKey in ipairs(groupKeys) do
            if options.args.DisplayManager.args.groupControl.args.groupFramesModern.args[groupKey] and
                options.args.DisplayManager.args.groupControl.args.groupFramesModern.args[groupKey].args then
                options.args.DisplayManager.args.groupControl.args.groupFramesModern.args[groupKey].args.keybindOverlay =
                    self:GenerateKeybindOverlayOptionsForGroup(groupKey)
            end
        end
    end

    -- Keybind Overlay has been moved to Keybind Manager
    return options
end

function ActionSlotManager:debug_asm(options, context)
    if options.args and options.args.debugTools and options.args.debugTools.args then
        options.args.debugTools.args.hotkeyDebug = {
            type = "group",
            name = L["hotkeyDebug"] or "Hotkey Debug",
            desc = L["hotkeyDebugDesc"] or "Debug tools for action slot and hotkey management",
            order = 1,
            args = {
                showHotkeyDebug = {
                    type = "execute",
                    name = L["showHotkeyDebug"] or "Show Hotkey Debug Table",
                    desc = L["showHotkeyDebugDesc"] or "Open a live table of all detected hotkeys.",
                    order = 1,
                    func = function() self:ShowDebugFrame_ASM() end,
                    width = "full",
                },
            }
        }
    end
    return options
end

function ActionSlotManager:splash_asm(options, context)
    if options.args and options.args.frameControlsGroup and options.args.frameControlsGroup.args then
        options.args.frameControlsGroup.args.overlayEditMode = {
            type = "execute",
            name = function()
                return self.overlayDragMode and "Lock Overlay Positioning" or "Unlock Overlay Positioning"
            end,
            desc = L["overlayEditModeDesc"] or "Enable drag mode to reposition keybind overlays for each group.",
            order = 2,
            width = "double",
            func = function()
                self:SetOverlayDragMode(not self.overlayDragMode)
            end,
        }
    end
    return options
end

function ActionSlotManager:GenerateKeybindOverlayOptionsForGroup(groupKey)
    local anchorPoints = {
        TOPLEFT = "TOPLEFT",
        TOP = "TOP",
        TOPRIGHT = "TOPRIGHT",
        LEFT = "LEFT",
        CENTER = "CENTER",
        RIGHT = "RIGHT",
        BOTTOMLEFT = "BOTTOMLEFT",
        BOTTOM = "BOTTOM",
        BOTTOMRIGHT = "BOTTOMRIGHT"
    }

    return {
        type = "group",
        name = L["Keybind Overlay"] or "Keybind Overlay",
        desc = L["Configure keybind overlay settings for this group."] or "Configure keybind overlay settings for this group.",
        inline = true,
        order = 999,
        args = {
            enabled = OptionsFactory:CreateToggle(L["optionsFactoryEnabled"] or "Show Keybind Overlay", L["optionsFactoryEnabledDesc"] or "Enable keybind overlay for this group only.",
                function() return self.db.global.modern.overlayEnabled[groupKey] end,
                function(_, val)
                    self.db.global.modern.overlayEnabled[groupKey] = val ~= false
                end,
                { order = 0 }
            ),
            fontSize = OptionsFactory:CreateRange(L["fontSize"] or "Font Size", L["optionsFactoryFontSizeDesc"] or "Font size for keybind overlays on this group's icons.",
                function() return self.db.global.modern.overlayFontSize[groupKey] end,
                function(_, val)
                    self.db.global.modern.overlayFontSize[groupKey] = val
                end,
                {
                    min = 8,
                    max = 24,
                    step = 1,
                    order = 1
                }
            ),
            anchor = OptionsFactory:CreateSelect(L["optionsFactoryAnchor"] or "Anchor Point", L["optionsFactoryAnchorDesc"] or "Where the overlay appears on the icon for this group.",
                function()
                    local anchor = self.db.global.modern.overlayAnchor[groupKey]
                    return (anchor and anchor.point) or "TOPRIGHT"
                end,
                function(_, val)
                    if not self.db.global.modern.overlayAnchor[groupKey] then
                        self.db.global.modern.overlayAnchor[groupKey] = {}
                    end
                    self.db.global.modern.overlayAnchor[groupKey].point = val
                end,
                {
                    values = anchorPoints,
                    order = 2
                }
            ),
        }
    }
end

function ActionSlotManager:GetDebugSections()
    local function keybindsSection()
        local lines = {}
        table.insert(lines, "|cffffd700All Hotkeys (by type):|r")
        local ASM = NAG:GetModule("ActionSlotManager")
        if ASM and ASM.ActionSlotsBy then
            for _, type in ipairs({ "spell", "item", "macro" }) do
                local count = 0
                for _ in pairs(ASM.ActionSlotsBy[type] or {}) do
                    count = count + 1
                end
                if count > 0 then
                    table.insert(lines, format("%s: %d entries", type, count))
                end
            end
        end
        return lines
    end

    return {
        { header = "Hotkeys", dataFn = keybindsSection },
    }
end

function ActionSlotManager:GetDebugControls()
    return {
        {
            type = "button",
            text = "Force Rescan",
            width = 120,
            onClick = function()
                for i = 1, 120 do
                    UpdateAction_ASM(i)
                end
                local KeybindManager = NAG:GetModule("KeybindManager")
                if KeybindManager then
                    KeybindManager:UpdateAllKeybinds()
                end
                if self.debugFrame and self.debugFrame.UpdateDebugFrame then
                    self.debugFrame:UpdateDebugFrame()
                end
            end
        }
    }
end

function ActionSlotManager:ShowDebugFrame_ASM()
    if not ns.DebugFrameUtil then
        self:Error("DebugFrameUtil not available")
        return
    end

    local function collectHotkeyRows()
        local rows = {}
        local function addRows(typeName)
            for id, slots in pairs(ActionSlotManager.ActionSlotsBy[typeName]) do
                local action = slots and ActionSlotManager.Actions[slots[1]]
                if action then
                    table.insert(rows, {
                        type = typeName,
                        id = id,
                        hotkey = action.HotKey or "",
                        slot = action.Slot or "",
                    })
                end
            end
        end
        addRows("spell")
        addRows("item")
        addRows("macro")
        return rows
    end

    ns.DebugFrameUtil:ShowDebugFrame(self, {
        title = "ActionSlotManager Hotkeys",
        refreshInterval = 1.0,
        sections = {
            {
                type = "table",
                header = "All Hotkeys (Live)",
                columns = {
                    { key = "type", label = "Type", width = 60 },
                    { key = "id", label = "ID", width = 60 },
                    { key = "hotkey", label = "Hotkey", width = 80 },
                    { key = "slot", label = "Slot", width = 40 },
                },
                rowsFn = collectHotkeyRows,
                sortField = "type"
            }
        }
    })
end

function ActionSlotManager:DiagnoseKeybinds()
    self:Print("=== Keybind Diagnostic Report ===")

    -- Check action slots populated
    local actionCount = 0
    for _ in pairs(self.Actions) do actionCount = actionCount + 1 end
    self:Print("Action slots populated: " .. actionCount)

    -- Check database flags
    self:Print("Legacy enabled: " .. tostring(self.db.global.legacy.enabled))
    self:Print("Modern overlays:")
    for group, enabled in pairs(self.db.global.modern.overlayEnabled) do
        self:Print("  " .. group .. ": " .. tostring(enabled))
    end

    -- Test GetSpellInfo structure
    self:Print("Testing WoWAPI.GetSpellInfo structure:")
    local testSpellInfo = WoWAPI.GetSpellInfo(100) -- Generic test spell
    if testSpellInfo then
        self:Print("  GetSpellInfo returned table:")
        self:Print("    name: " .. tostring(testSpellInfo.name))
        self:Print("    spellID: " .. tostring(testSpellInfo.spellID))
        self:Print("    iconID: " .. tostring(testSpellInfo.iconID))
        self:Print("    originalIconID: " .. tostring(testSpellInfo.originalIconID))
    else
        self:Print("  ERROR: GetSpellInfo returned nil for test spell")
    end

    -- Test GetSpellTabInfo structure
    self:Print("Testing WoWAPI.GetSpellTabInfo structure:")
    local testTabInfo = WoWAPI.GetSpellTabInfo(1)
    if testTabInfo then
        self:Print("  GetSpellTabInfo returned table:")
        self:Print("    name: " .. tostring(testTabInfo.name))
        self:Print("    itemIndexOffset: " .. tostring(testTabInfo.itemIndexOffset))
        self:Print("    numSpellBookItems: " .. tostring(testTabInfo.numSpellBookItems))
    else
        self:Print("  ERROR: GetSpellTabInfo returned nil")
    end

    -- Check managed frames (from KeybindManager)
    local KeybindManager = NAG:GetModule("KeybindManager")
    local frameCount = 0
    local framesWithSpells = 0
    local framesWithItems = 0
    if KeybindManager and KeybindManager.managedFrames then
        for frame in pairs(KeybindManager.managedFrames) do
            frameCount = frameCount + 1
            if frame.spellId then framesWithSpells = framesWithSpells + 1 end
            if frame.itemId then framesWithItems = framesWithItems + 1 end
        end
    end
    self:Print("Managed frames: " .. frameCount)
    self:Print("  With spellId: " .. framesWithSpells)
    self:Print("  With itemId: " .. framesWithItems)

    -- Check ActionSlotsBy tables
    self:Print("ActionSlotsBy counts:")
    -- Check ActionSlotsBy tables (from ActionSlotManager)
    local ASM = NAG:GetModule("ActionSlotManager")
    if ASM and ASM.ActionSlotsBy then
        for type, tbl in pairs(ASM.ActionSlotsBy) do
            local count = 0
            for _ in pairs(tbl) do count = count + 1 end
            self:Print("  " .. type .. ": " .. count)
        end
    else
        self:Print("  ActionSlotManager not available")
    end

    self:Print("=== End Diagnostic Report ===")
end

